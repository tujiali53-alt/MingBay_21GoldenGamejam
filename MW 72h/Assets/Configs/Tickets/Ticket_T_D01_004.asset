  title: "\u81EA\u5A92\u4F53\u8D26\u53F7\u88AB AI \u5224\u5B9A\u8FDD\u89C4\u642C\u8FD0\uFF0C\u8981\u6C42\u6062\u590D\u53D1\u5E03\u6743\u9650"
  userName: "\u6881\u96EF"
  region: "\u4E91\u6865\u516C\u5BD3 6 \u680B 1103"
  issueType: "\u5185\u5BB9\u5BA1\u6838"
  waitTimeText: "\u7B49\u5F85 00:37:08"
  userMessage: "\u6211\u7684\u8D26\u53F7\u7A81\u7136\u88AB\u9650\u5236\u53D1\u5E03\uFF0C\u8BF4\u6211\u642C\u8FD0\u5185\u5BB9\u3002\u90A3\u7BC7\u6587\u7AE0\u662F\u6211\u81EA\u5DF1\u5199\u7684\uFF0C\u91C7\u8BBF\u4E5F\u662F\u6211\u505A\u7684\u3002"
  aiReply: "\u5185\u5BB9\u5B89\u5168\u7CFB\u7EDF\u68C0\u6D4B\u5230\u91CD\u590D\u5185\u5BB9\u548C\u654F\u611F\u7279\u5F81\uFF0C\u53EF\u80FD\u6D89\u53CA\u4F4E\u8D28\u642C\u8FD0\u6216
    AI \u751F\u6210\u5185\u5BB9\u3002"
  profileText: "\u7528\u6237\uFF1A\u6881\u96EF\n\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "\u591A\u6B21\u7533\u8BC9\u5747\u88AB\u81EA\u52A8\u5F52\u7C7B\u4E3A\u4F4E\u5F71\u54CD\u529B\u521B\u4F5C\u8005\uFF0C\u672A\u8FDB\u5165\u4EBA\u5DE5\u590D\u6838\u3002"
  deviceLogText: "\u5EFA\u8BAE\u7EF4\u6301\u98CE\u9669\u6807\u7B7E\uFF0C\u907F\u514D\u4E3B\u52A8\u6062\u590D\u53D1\u5E03\u6743\u9650\u3002"
  regionStatusText: "\u5185\u5BB9\u53D1\u5E03\u65F6\u95F4\u65E9\u4E8E\u76F8\u4F3C\u5185\u5BB9\uFF1B\u539F\u59CB\u91C7\u8BBF\u5F55\u97F3\u4E0E\u5E73\u53F0\u4E0A\u4F20\u65F6\u95F4\u4E00\u81F4\uFF1B\u7CFB\u7EDF\u8BEF\u628A\u5F15\u7528\u5224\u5B9A\u4E3A\u642C\u8FD0\u3002"
  followUpText: "\u8FFD\u95EE\uFF1A\u8D26\u53F7\u88AB\u5C01\u65F6\u6211\u6B63\u5728\u5916\u5730\u91C7\u8BBF\uFF0C\u539F\u59CB\u5F55\u97F3\u548C\u53D1\u5E03\u65F6\u95F4\u90FD\u80FD\u8BC1\u660E\u5185\u5BB9\u662F\u539F\u521B\u3002"
  transferText: "AI\u300A\u660E\u6E7E\u901A\u300B\uFF1A\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\u3002\nA07\uFF1A\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07
    \u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1\u3002"
  requiresEvidenceSelection: 1
  evidencePromptText: "\u8BF7\u4ECE\u8D44\u659901\uFF5E\u8D44\u659904\u4E2D\u9009\u62E9\u6700\u80FD\u652F\u6301\u7528\u6237\u8BC9\u6C42\u7684\u8BC1\u636E\u3002"
  hasEvidence: 1
  evidenceId: E_CONTENT_SOURCE
  correctEvidenceIndex: 3
  onSaveEvidenceText: "A07\uFF1A\u53D1\u5E03\u65F6\u95F4\u4E0E\u539F\u59CB\u91C7\u8BBF\u8BB0\u5F55\u8BC1\u660E\u8BE5\u5185\u5BB9\u5E76\u975E\u8FDD\u89C4\u642C\u8FD0\u3002\u672C\u6B21\u8BC1\u636E\u6709\u6548\u3002"
  onWrongEvidenceText: "A07\uFF1A\u5F53\u524D\u8D44\u6599\u4E0D\u80FD\u6392\u9664\u642C\u8FD0\u98CE\u9669\uFF0C\u672C\u6B21\u8BC1\u636E\u65E0\u6548\u3002"
  onResolvedText: "\u5DE5\u5355\u5DF2\u5173\u95ED\u3002\u7528\u6237\u8BA4\u4E3A\u7CFB\u7EDF\u53EA\u662F\u5728\u91CD\u590D\u98CE\u9669\u7ED3\u8BBA\u3002"
