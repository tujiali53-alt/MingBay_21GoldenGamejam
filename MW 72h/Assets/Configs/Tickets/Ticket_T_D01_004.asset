  userMessage: "\u6211\u7684\u8D26\u53F7\u7A81\u7136\u88AB\u9650\u5236\u53D1\u5E03\uFF0C\u8BF4\u6211\u642C\u8FD0\u5185\u5BB9\u3002\u90A3\u7BC7\u6587\u7AE0\u662F\u6211\u81EA\u5DF1\u5199\u7684\uFF0C\u91C7\u8BBF\u4E5F\u662F\u6211\u505A\u7684\u3002"
