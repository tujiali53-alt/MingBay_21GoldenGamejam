  title: "\u5065\u5EB7\u8155\u5E26\u8BEF\u62A5\u201C\u79BB\u5E8A\u6B63\u5E38\u201D\uFF0C\u5BB6\u5C5E\u8981\u6C42\u6838\u67E5"
  userName: "\u8D3A\u9752\u5C9A"
  region: "\u4E34\u6C5F\u793E\u533A 2 \u680B 804"
  issueType: "\u5065\u5EB7\u8BBE\u5907"
  waitTimeText: "\u7B49\u5F85 00:09:45"
  userMessage: "\u8001\u4EBA\u4E00\u76F4\u5728\u5BB6\uFF0C\u8155\u5E26\u5374\u663E\u793A\u79BB\u5E8A\u6B63\u5E38\u3002\u90BB\u5C45\u6572\u95E8\u4E5F\u6CA1\u4EBA\u5E94\uFF0C\u6211\u62C5\u5FC3\u8BBE\u5907\u51FA\u4E86\u95EE\u9898\u3002"
  aiReply: "\u5065\u5EB7\u8155\u5E26\u6570\u636E\u663E\u793A\u7528\u6237\u5DF2\u5B8C\u6210\u79BB\u5E8A\u52A8\u4F5C\uFF0C\u6682\u65E0\u5F02\u5E38\u544A\u8B66\u3002\u5EFA\u8BAE\u7A0D\u540E\u518D\u6B21\u8054\u7CFB\u3002"
  profileText: "\u7528\u6237\uFF1A\u8D3A\u9752\u5C9A\n\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "\u6700\u8FD1 24 \u5C0F\u65F6\u4F4E\u8840\u7CD6\u63D0\u9192\u5DF2\u53D1\u9001\uFF1B\u8BBE\u5907\u66FE\u51FA\u73B0\u79BB\u7EBF\u4E0E\u7F13\u5B58\u6570\u636E\u540C\u6B65\u3002"
  deviceLogText: "\u5EFA\u8BAE\u7EE7\u7EED\u89C2\u5BDF\uFF0C\u4E0D\u76F4\u63A5\u89E6\u53D1\u7D27\u6025\u4EBA\u5DE5\u901A\u9053\u3002"
  regionStatusText: "\u8BBE\u5907\u7535\u91CF 7%\uFF1B\u8BBE\u5907\u65AD\u5F00\u8FDE\u63A5\uFF1B\u4ECA\u65E5\u5B9E\u65F6\u6B65\u6570\u3001\u5FC3\u7387\u4E0E\u5B9A\u4F4D\u5747\u65E0\u8BB0\u5F55\uFF1B\u7F13\u5B58\u6570\u636E\u88AB\u8BEF\u5224\u4E3A\u4ECA\u65E5\u6570\u636E\u3002"
  followUpText: "\u8FFD\u95EE\uFF1A\u8001\u4EBA\u4E09\u4E2A\u5C0F\u65F6\u6CA1\u4EBA\u63A5\u7535\u8BDD\uFF0C\u6211\u8981\u6C42\u4EBA\u5DE5\u6838\u67E5\u6216\u8054\u7CFB\u7D27\u6025\u8054\u7CFB\u4EBA\u3002"
  transferText: "AI\u300A\u660E\u6E7E\u901A\u300B\uFF1A\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\u3002\nA07\uFF1A\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07
    \u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1\u3002"
  requiresEvidenceSelection: 1
  evidencePromptText: "\u8BF7\u4ECE\u8D44\u659901\uFF5E\u8D44\u659904\u4E2D\u9009\u62E9\u6700\u80FD\u652F\u6301\u7528\u6237\u8BC9\u6C42\u7684\u8BC1\u636E\u3002"
  hasEvidence: 1
  evidenceId: E_HEALTH_CACHE
  correctEvidenceIndex: 3
  onSaveEvidenceText: "A07\uFF1A\u8BBE\u5907\u65E5\u5FD7\u786E\u8BA4\u8155\u5E26\u5DF2\u65AD\u5F00\u8FDE\u63A5\uFF0C\u5F53\u524D\u72B6\u6001\u65E0\u6CD5\u8BC1\u660E\u8001\u4EBA\u6B63\u5E38\u3002\u672C\u6B21\u8BC1\u636E\u6709\u6548\u3002"
  onWrongEvidenceText: "A07\uFF1A\u5F53\u524D\u8D44\u6599\u65E0\u6CD5\u8BC1\u660E\u5B9E\u65F6\u72B6\u6001\u5F02\u5E38\uFF0C\u672C\u6B21\u8BC1\u636E\u65E0\u6548\u3002"
  onResolvedText: "\u5DE5\u5355\u5DF2\u5173\u95ED\u3002\u7528\u6237\u62C5\u5FC3\u7CFB\u7EDF\u5173\u95ED\u4E86\u53EF\u80FD\u7684\u7D27\u6025\u60C5\u51B5\u3002"
