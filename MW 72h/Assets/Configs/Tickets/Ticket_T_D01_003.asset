  title: "\u5065\u5EB7\u8155\u5E26\u8BEF\u62A5\u201C\u79BB\u5E8A\u6B63\u5E38\u201D\uFF0C\u5BB6\u5C5E\u8981\u6C42\u6838\u67E5"
  userName: "\u8D3A\u9752\u5C9A"
  region: "\u4E34\u6C5F\u793E\u533A 2 \u680B 804"
  issueType: "\u5065\u5EB7\u8BBE\u5907"
  waitTimeText: "\u7B49\u5F85 00:09:45"
  userMessage: "\u8001\u4EBA\u4E00\u76F4\u5728\u5BB6\uFF0C\u8155\u5E26\u5374\u663E\u793A\u79BB\u5E8A\u6B63\u5E38\u3002\u90BB\u5C45\u6572\u95E8\u4E5F\u6CA1\u4EBA\u5E94\uFF0C\u6211\u62C5\u5FC3\u8BBE\u5907\u51FA\u4E86\u95EE\u9898\u3002"
  aiReply: "\u5065\u5EB7\u8155\u5E26\u6570\u636E\u663E\u793A\u7528\u6237\u5DF2\u5B8C\u6210\u79BB\u5E8A\u52A8\u4F5C\uFF0C\u6682\u65E0\u5F02\u5E38\u544A\u8B66\u3002\u5EFA\u8BAE\u7A0D\u540E\u518D\u6B21\u8054\u7CFB\u3002"
  profileText: "\u7528\u6237\uFF1A\u8D3A\u9752\u5C9A\n\u4F4F\u5740\uFF1A\u4E34\u6C5F\u793E\u533A2\u680B804\n\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "T_HIS_1209\uFF1A\u5BB6\u5C5E\u53CD\u9988\u8001\u4EBA\u591C\u95F4\u4F4E\u8840\u7CD6\uFF0C\u5065\u5EB7\u8155\u5E26\u544A\u8B66\uFF0CAI\u5224\u5B9A\u4E3A\u201C\u4E2A\u4F53\u6D3B\u52A8\u5DEE\u5F02\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\nT_HIS_1230\uFF1A\u7528\u6237\u8981\u6C42\u589E\u52A0\u7D27\u6025\u8054\u7CFB\u4EBA\u6743\u9650\uFF0CAI\u5224\u5B9A\u201C\u6743\u9650\u914D\u7F6E\u8BF4\u660E\u5DF2\u53D1\u9001\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\nT_HIS_1261\uFF1A\u7528\u6237\u54A8\u8BE2\u5B9E\u65F6\u5B9A\u4F4D\u5F02\u5E38\uFF0CAI\u5224\u5B9A\u4E3A\u201C\u8BBE\u5907\u77ED\u65F6\u79BB\u7EBF\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\n\u5907\u6CE8\uFF1A\u8001\u4EBA\u7167\u62A4\u6863\u6848\u4E2D\u5B58\u5728\u201C\u4F4E\u8840\u7CD6\u53F2\u201D\u548C\u201C\u72EC\u5C45\u201D\u6807\u7B7E\u3002"
  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\u8BBE\u5907\u6570\u636E\u663E\u793A\u8001\u4EBA\u4ECA\u65E5\u6D3B\u52A8\u6570\u636E\u5904\u4E8E\u6B63\u5E38\u8303\u56F4\uFF0C\u6682\u672A\u89E6\u53D1\u7D27\u6025\u544A\u8B66\u3002\u5982\u4ECD\u6709\u62C5\u5FE7\uFF0C\u53EF\u901A\u8FC7\u5BB6\u5EAD\u6210\u5458\u7AEF\u7EE7\u7EED\u5173\u6CE8\u5065\u5EB7\u5468\u62A5\u3002\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\u5BB6\u5C5E\u7126\u8651
    / \u91CD\u590D\u786E\u8BA4 / \u6682\u65E0\u5F02\u5E38\u3002\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\u4E0D\u5EFA\u8BAE\u76F4\u63A5\u89E6\u53D1\u7D27\u6025\u4EBA\u5DE5\u901A\u9053\uFF0C\u907F\u514D\u5360\u7528\u7167\u62A4\u8D44\u6E90\u3002"
  regionStatusText: "\u5065\u5EB7\u8155\u5E26\u8BBE\u5907\u7F16\u53F7\uFF1AHB-7742\n00:31:12
    \u8BBE\u5907\u7535\u91CF7%\u3002\n01:08:45 \u8BBE\u5907\u65AD\u5F00\u8FDE\u63A5\u3002\n06:42:03
    \u7CFB\u7EDF\u663E\u793A\u79BB\u5E8A\u6B63\u5E38\u3002\n\u6570\u636E\u6765\u6E90\uFF1A\u6628\u65E5\u7F13\u5B58\u540C\u6B65\u3002\n\u4ECA\u65E5\u5B9E\u65F6\u6B65\u6570\uFF1A\u65E0\u8BB0\u5F55\u3002\n\u4ECA\u65E5\u5FC3\u7387\u6570\u636E\uFF1A\u65E0\u8BB0\u5F55\u3002\n\u4ECA\u65E5\u5B9A\u4F4D\u6570\u636E\uFF1A\u65E0\u8BB0\u5F55\u3002\n\u5F53\u524D\u8BBE\u5907\u72B6\u6001\uFF1A\u79BB\u7EBF\u3002\n\u7CFB\u7EDF\u81EA\u52A8\u7ED3\u8BBA\uFF1A\u6D3B\u52A8\u72B6\u6001\u6B63\u5E38\u3002\n\u5F02\u5E38\u8BF4\u660E\uFF1A\u7F13\u5B58\u6570\u636E\u88AB\u8BEF\u6807\u4E3A\u4ECA\u65E5\u6570\u636E\u3002"
  followUpText: "\u8FFD\u95EE\uFF1A\u8001\u4EBA\u4E09\u4E2A\u5C0F\u65F6\u6CA1\u4EBA\u63A5\u7535\u8BDD\uFF0C\u6211\u8981\u6C42\u4EBA\u5DE5\u6838\u67E5\u6216\u8054\u7CFB\u7D27\u6025\u8054\u7CFB\u4EBA\u3002"
  followUpLines: []
  transferText: "AI\u300A\u660E\u6E7E\u901A\u300B\uFF1A\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\u3002\nA07\uFF1A\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07
