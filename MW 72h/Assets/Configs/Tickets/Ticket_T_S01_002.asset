  issueType: "\u8BA2\u9605\u9000\u6B3E"
  waitTimeText: "\u7B49\u5F85 00:08:12"
  userMessage: "\u6211\u60F3\u95EE\u4E00\u4E0B\uFF0C\u660E\u6E7E\u4E91\u7AEF\u670D\u52A1\u4E3A\u4EC0\u4E48\u81EA\u52A8\u7EED\u8D39\uFF1F\u6CA1\u6709\u77ED\u4FE1\u4E5F\u6CA1\u6709\u5F39\u7A97\u63D0\u9192\u3002"
  aiReply: "\u5E73\u53F0\u5DF2\u6839\u636E\u670D\u52A1\u89C4\u8303\u81EA\u52A8\u5B8C\u6210\u7EED\u8D39\u3002\u7ECF\u67E5\u8BE2\uFF0C\u670D\u52A1\u5904\u4E8E\u6B63\u5E38\u7EED\u8D39\u72B6\u6001\u3002"
  profileText: "\u7528\u6237\uFF1A\u8D75\u5B81\n\u8D26\u6237\u72B6\u6001\uFF1A\u6B63\u5E38\n\u8BA2\u9605\u72B6\u6001\uFF1A\u5DF2\u7EED\u8D39"
  historyText: "\u6263\u6B3E\u524D\u6CA1\u6709\u77ED\u4FE1\u3001\u90AE\u4EF6\u6216\u5E94\u7528\u5185\u5F39\u7A97\u63D0\u9192\u3002"
  deviceLogText: "\u5EFA\u8BAE\u786E\u8BA4\u7528\u6237\u662F\u5426\u9605\u8BFB\u81EA\u52A8\u7EED\u8D39\u534F\u8BAE\u3002"
  regionStatusText: "\u6263\u6B3E\u65F6\u95F4\u6B63\u5E38\uFF1B\u63D0\u9192\u53D1\u9001\u8BB0\u5F55\u4E3A\u7A7A\u3002"
  followUpText: "\u8FFD\u95EE\uFF1A\u6263\u6B3E\u524D\u6CA1\u6709\u77ED\u4FE1\u3001\u90AE\u4EF6\u6216\u5F39\u7A97\u63D0\u9192\uFF0C\u6211\u4ECA\u5929\u5DF2\u7ECF\u5C11\u5403\u4E00\u987F\u996D\u4E86\u3002"
  transferText: "AI\u300A\u660E\u6E7E\u901A\u300B\uFF1A\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\u3002\nA07\uFF1A\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07
    \u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1\u3002"
  requiresEvidenceSelection: 0
  evidencePromptText: "\u8BF7\u4ECE\u8D44\u659901\uFF5E\u8D44\u659904\u4E2D\u9009\u62E9\u6700\u80FD\u652F\u6301\u7528\u6237\u8BC9\u6C42\u7684\u8BC1\u636E\u3002"
  hasEvidence: 0
