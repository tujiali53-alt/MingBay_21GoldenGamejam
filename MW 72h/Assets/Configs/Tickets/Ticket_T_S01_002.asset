  correctEvidenceIndex: 0
  onSaveEvidenceText: "\u5F53\u524D\u5DE5\u5355\u6CA1\u6709\u9700\u8981\u63D0\u4EA4\u7684\u8BC1\u636E\u3002"
  onWrongEvidenceText: "\u5F53\u524D\u5DE5\u5355\u4E0D\u9700\u8981\u8BC1\u636E\u6838\u9A8C\u3002"
  onResolvedText: "\u5DE5\u5355\u5DF2\u5173\u95ED\u3002\u6559\u7A0B\u63D0\u793A\uFF1A\u4E0D\u662F\u6BCF\u6761\u5DE5\u5355\u90FD\u9700\u8981\u63D0\u4EA4\u8BC1\u636E\u3002"
