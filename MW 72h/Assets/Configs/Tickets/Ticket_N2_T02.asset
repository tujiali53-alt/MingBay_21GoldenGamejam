  issueType: "\u7269\u4E1A\u62A5\u4FEE"
  waitTimeText: "\u7B49\u5F85 00:00:00"
  userMessage: "\u7535\u68AF\u53C8\u574F\u4E86\u3002\u6211\u5750\u8F6E\u6905\uFF0C\u4ECA\u5929\u7B2C\u4E09\u6B21\u4E0B\u4E0D\u4E86\u697C\u3002\n\u7CFB\u7EDF\u4E00\u76F4\u8BF4\u6211\u91CD\u590D\u63D0\u4EA4\uFF0C\u53EF\u95EE\u9898\u6839\u672C\u6CA1\u89E3\u51B3\u3002"
  aiReply: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A\n\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u540C\u7C7B\u62A5\u4FEE\u5DF2\u63D0\u4EA4\uFF0C\u8BF7\u52FF\u91CD\u590D\u53D1\u9001\u3002"
  initialDialogueLines:
  - speakerId: User_LuCheng
    speakerLabel: "\u9646\u627F"
    text: "\u7535\u68AF\u53C8\u574F\u4E86\u3002\u6211\u5750\u8F6E\u6905\uFF0C\u4ECA\u5929\u7B2C\u4E09\u6B21\u4E0B\u4E0D\u4E86\u697C\u3002"
    fromUser: 1
  - speakerId: User_LuCheng
    speakerLabel: "\u9646\u627F"
    text: "\u7CFB\u7EDF\u4E00\u76F4\u8BF4\u6211\u91CD\u590D\u63D0\u4EA4\uFF0C\u53EF\u95EE\u9898\u6839\u672C\u6CA1\u89E3\u51B3\u3002"
    fromUser: 1
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A"
    fromUser: 0
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u540C\u7C7B\u62A5\u4FEE\u5DF2\u63D0\u4EA4\uFF0C\u8BF7\u52FF\u91CD\u590D\u53D1\u9001\u3002"
    fromUser: 0
  transferDialogueLines:
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
    fromUser: 0
  evidenceCorrectDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5DF2\u6838\u5BF9\u4E09\u6B21\u7535\u68AF\u6545\u969C\u7801\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u4E09\u6B21\u6545\u969C\u7C7B\u578B\u4E0D\u540C\uFF0C\u7CFB\u7EDF\u9519\u8BEF\u5408\u5E76\u4E3A\u91CD\u590D\u8BF7\u6C42\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u6211\u4F1A\u91CD\u65B0\u6D3E\u53D1\u7EF4\u4FEE\u5355\uFF0C\u5E76\u7533\u8BF7\u65E0\u969C\u788D\u5E94\u6025\u901A\u9053\u3002"
    fromUser: 0
  - speakerId: User_LuCheng
    speakerLabel: "\u9646\u627F"
    text: "\u8C22\u8C22\u3002\u5BF9\u6211\u6765\u8BF4\uFF0C\u8FD9\u4E0D\u662F\u50AC\u5355\uFF0C\u662F\u51FA\u4E0D\u4E86\u95E8\u3002"
    fromUser: 1
  evidenceWrongDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u76EE\u524D\u7CFB\u7EDF\u663E\u793A\u5DF2\u6709\u540C\u7C7B\u62A5\u4FEE\uFF0C\u9700\u7B49\u5F85\u7269\u4E1A\u7EDF\u4E00\u5904\u7406\u3002"
    fromUser: 0
  - speakerId: User_LuCheng
    speakerLabel: "\u9646\u627F"
    text: "\u6211\u7B49\u7684\u4E0D\u662F\u5904\u7406\u6D41\u7A0B\uFF0C\u6211\u7B49\u7684\u662F\u80FD\u4E0B\u697C\u3002"
    fromUser: 1
  profileText: "-\u7528\u6237\uFF1A\u9646\u627F\n\n-\u4F4F\u5740\uFF1A\u9752\u85E4\u82B1\u56ED
