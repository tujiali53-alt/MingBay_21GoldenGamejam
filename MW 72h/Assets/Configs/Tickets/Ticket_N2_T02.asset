  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\n\n\u201C\u60A8\u597D\uFF0C\u60A8\u7684\u540C\u7C7B\u62A5\u4FEE\u5DF2\u8FDB\u5165\u7269\u4E1A\u5904\u7406\u6D41\u7A0B\u3002\u8BF7\u52FF\u91CD\u590D\u63D0\u4EA4\uFF0C\u4EE5\u514D\u5F71\u54CD\u7CFB\u7EDF\u6D3E\u5355\u6548\u7387\u3002\u201D\n\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\n\n\u91CD\u590D\u8BF7\u6C42
    / \u540C\u7C7B\u62A5\u4FEE / \u7B49\u5F85\u7269\u4E1A\u5904\u7406\n\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\n\n\u5408\u5E76\u5DE5\u5355\uFF0C\u4E0D\u5EFA\u8BAE\u91CD\u590D\u6D3E\u5355\u3002"
  regionStatusText: "00:12 \u6545\u969C\u7801 E17\uFF1A\u8F7F\u53A2\u95E8\u65E0\u6CD5\u95ED\u5408\u3002\n\n01:48
