  issueType: "\u4EA4\u901A\u914D\u9001"
  waitTimeText: "\u7B49\u5F85 00:00:00"
  userMessage: "\u6211\u6CA1\u7ED5\u8DEF\uFF01\u4F60\u4EEC\u5BFC\u822A\u628A\u6211\u5BFC\u5230\u65BD\u5DE5\u8DEF\u6BB5\uFF0C\u6211\u6309\u7CFB\u7EDF\u7ED9\u7684\u8DEF\u7EBF\u8D70\uFF0C\u6700\u540E\u8FD8\u6263\u621160\u5757\u3002\u4E00\u5929\u767D\u8DD1\u4E86\u3002\u6211\u73B0\u5728\u8FD8\u5728\u9001\u5355\uFF0C\u522B\u518D\u8BA9\u6211\u586B\u4EC0\u4E48\u8868\u4E86\uFF0C\u76F4\u63A5\u7ED9\u6211\u64A4\u9500\uFF01"
  aiReply: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A\n\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u5E73\u53F0\u5DF2\u6839\u636E\u670D\u52A1\u89C4\u8303\u81EA\u52A8\u751F\u6210\u6263\u6B3E\u8BB0\u5F55\u3002\u5982\u60A8\u5BF9\u7ED3\u679C\u6709\u7591\u95EE\uFF0C\u53EF\u572824\u5C0F\u65F6\u5185\u63D0\u4EA4\u7533\u8BC9\u3002"
  initialDialogueLines:
  - speakerId: User_JiChi
    speakerLabel: "\u5B63\u9A70"
    text: "\u6211\u6CA1\u7ED5\u8DEF\uFF01\u4F60\u4EEC\u5BFC\u822A\u628A\u6211\u5BFC\u5230\u65BD\u5DE5\u8DEF\u6BB5\uFF0C\u6211\u6309\u7CFB\u7EDF\u7ED9\u7684\u8DEF\u7EBF\u8D70\uFF0C\u6700\u540E\u8FD8\u6263\u621160\u5757\u3002\u4E00\u5929\u767D\u8DD1\u4E86\u3002\u6211\u73B0\u5728\u8FD8\u5728\u9001\u5355\uFF0C\u522B\u518D\u8BA9\u6211\u586B\u4EC0\u4E48\u8868\u4E86\uFF0C\u76F4\u63A5\u7ED9\u6211\u64A4\u9500\uFF01"
    fromUser: 1
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A"
    fromUser: 0
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u5E73\u53F0\u5DF2\u6839\u636E\u670D\u52A1\u89C4\u8303\u81EA\u52A8\u751F\u6210\u6263\u6B3E\u8BB0\u5F55\u3002\u5982\u60A8\u5BF9\u7ED3\u679C\u6709\u7591\u95EE\uFF0C\u53EF\u572824\u5C0F\u65F6\u5185\u63D0\u4EA4\u7533\u8BC9\u3002"
    fromUser: 0
  transferDialogueLines:
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
    fromUser: 0
  evidenceCorrectDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5DF2\u6838\u5BF9\u8BA2\u5355\u8DEF\u7EBF\u4E0E\u5E73\u53F0\u5BFC\u822A\u65E5\u5FD7\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u7528\u6237\u5B9E\u9645\u884C\u9A76\u8DEF\u5F84\u4E0E\u7CFB\u7EDF\u63A8\u8350\u8DEF\u5F84\u4E00\u81F4\uFF0C\u7ED5\u884C\u539F\u56E0\u6765\u81EA\u65BD\u5DE5\u5C01\u8DEF\u540E\u7684\u5730\u56FE\u5EF6\u8FDF\u66F4\u65B0\uFF0C\u5E76\u975E\u9A91\u624B\u4E3B\u52A8\u504F\u79BB\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u6211\u4F1A\u5C06\u5BFC\u822A\u65E5\u5FD7\u4F5C\u4E3A\u8BC1\u636E\u8F6C\u4EA4\u4EBA\u5DE5\u590D\u6838\u3002"
    fromUser: 0
  - speakerId: User_JiChi
    speakerLabel: "\u5B63\u9A70"
    text: "\u5BF9\uFF0C\u5C31\u662F\u8FD9\u4E2A\uFF01\u522B\u518D\u8BA9\u6211\u81EA\u5DF1\u8BC1\u660E\u6211\u6CA1\u9519\u4E86\u3002"
    fromUser: 1
  evidenceWrongDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u975E\u5E38\u62B1\u6B49\uFF0C\u540E\u53F0\u8FD9\u8FB9\u5E76\u672A\u67E5\u8BE2\u5230\u76F8\u5173\u6570\u636E\uFF0C\u5177\u4F53\u7ED3\u679C\u9700\u7B49\u5F85\u5E73\u53F0\u590D\u6838\u3002"
    fromUser: 0
  - speakerId: User_JiChi
    speakerLabel: "\u5B63\u9A70"
    text: "\u4F60\u4EEC\u662F\u4E0D\u662F\u53EA\u770B\u7ED3\u679C\uFF1F\uFF1F\u7B97\u4E86\uFF0C\u6211\u7EE7\u7EED\u8DD1\u5355\uFF0C\u665A\u4E0A\u6211\u518D\u6765\u6295\u8BC9\u3002"
    fromUser: 1
  profileText: "-\u7528\u6237\uFF1A\u5B63\u9A70\n\n-\u4F4F\u5740\uFF1A\u65E7\u6E2F\u7247\u533A
    4\u680B 602\n\n-\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\n-\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "\u8FD114\u5929\u5185\uFF0C\u7528\u6237\u63D0\u4EA4\u8FC74\u6B21\u914D\u9001\u7533\u8BC9\u3002\n\nT_HIS_1012\uFF1A\u8D85\u65F6\u7533\u8BC9\uFF0CAI\u5224\u5B9A\u4E3A\u201C\u9A91\u624B\u914D\u9001\u6548\u7387\u4E0D\u8DB3\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\n\nT_HIS_1066\uFF1A\u6076\u52A3\u5929\u6C14\u5EF6\u8BEF\uFF0CAI\u5224\u5B9A\u4E3A\u201C\u5916\u90E8\u73AF\u5883\u4E0D\u5F71\u54CD\u670D\u52A1\u627F\u8BFA\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\n\nT_HIS_1091\uFF1A\u8DEF\u7EBF\u504F\u79BB\u6263\u6B3E\uFF0CAI\u5224\u5B9A\u4E3A\u201C\u8BC1\u636E\u4E0D\u8DB3\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\n\n\u5907\u6CE8\uFF1A\u8BE5\u7528\u6237\u8FDE\u7EED\u4E09\u6B21\u7533\u8BC9\u5931\u8D25\u540E\uFF0C\u7CFB\u7EDF\u6807\u7B7E\u53D8\u66F4\u4E3A\u201C\u9AD8\u9891\u4E89\u8BAE\u7528\u6237\u201D\u3002"
  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\n\n\u201C\u60A8\u597D\uFF0C\u5E73\u53F0\u5DF2\u6839\u636E\u8BA2\u5355\u8F68\u8FF9\u81EA\u52A8\u5224\u5B9A\u8DEF\u7EBF\u504F\u79BB\u3002\u82E5\u60A8\u4ECD\u6709\u7591\u95EE\uFF0C\u53EF\u8865\u5145\u66F4\u591A\u6750\u6599\u540E\u91CD\u65B0\u63D0\u4EA4\u7533\u8BC9\u3002\u201D\n\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\n\n\u8DEF\u7EBF\u504F\u79BB
    / \u7528\u6237\u7533\u8BC9\u8BC1\u636E\u4E0D\u8DB3 / \u9AD8\u9891\u4E89\u8BAE\n\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\n\n\u4F18\u5148\u5F15\u5BFC\u7528\u6237\u81EA\u52A9\u7533\u8BC9\uFF0C\u4E0D\u5EFA\u8BAE\u76F4\u63A5\u8F6C\u4EBA\u5DE5\u3002"
  regionStatusText: "\u8BA2\u5355\u7F16\u53F7\uFF1AMW-FD-7721\n\n\u7CFB\u7EDF\u63A8\u8350\u8DEF\u7EBF\uFF1A\u660E\u6E7E\u5357\u8DEF
