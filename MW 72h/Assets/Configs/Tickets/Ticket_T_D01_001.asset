  profileText: "\u7528\u6237\uFF1A\u674E\u9A70\n\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "\u8FD1 14 \u5929\u63D0\u4EA4\u8FC7 4 \u6B21\u914D\u9001\u7533\u8BC9\uFF1B\u540C\u4E00\u8DEF\u6BB5\u591A\u6B21\u51FA\u73B0\u65BD\u5DE5\u7ED5\u884C\u3002"
  deviceLogText: "\u5EFA\u8BAE\u7EF4\u6301\u7CFB\u7EDF\u5224\u5B9A\uFF0C\u4F18\u5148\u5F15\u5BFC\u7528\u6237\u81EA\u884C\u7533\u8BC9\u3002"
  regionStatusText: "\u8BA2\u5355 MW-FD-7721\uFF1B\u5BFC\u822A\u8DEF\u7EBF\u7ECF\u8FC7\u5DF2\u5C01\u95ED\u9053\u8DEF\uFF1B\u5730\u56FE\u66F4\u65B0\u65F6\u95F4\u665A\u4E8E\u65BD\u5DE5\u65F6\u95F4\u3002"
  followUpText: "\u8FFD\u95EE\uFF1A\u6211\u7533\u8BC9\u8FC7\u4E09\u6B21\uFF0C\u90FD\u662F\u201C\u8BC1\u636E\u4E0D\u8DB3\u201D\u3002\u4E00\u4E2A\u9A91\u624B\u600E\u4E48\u8BC1\u660E\u65BD\u5DE5\u5C01\u8DEF\uFF1F"
  transferText: "AI\u300A\u660E\u6E7E\u901A\u300B\uFF1A\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\u3002\nA07\uFF1A\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07
    \u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1\u3002"
  requiresEvidenceSelection: 1
  evidencePromptText: "\u8BF7\u4ECE\u8D44\u659901\uFF5E\u8D44\u659904\u4E2D\u9009\u62E9\u6700\u80FD\u652F\u6301\u7528\u6237\u8BC9\u6C42\u7684\u8BC1\u636E\u3002"
  hasEvidence: 1
  evidenceId: E_ROUTE_CONSTRUCTION
  correctEvidenceIndex: 3
  onSaveEvidenceText: "A07\uFF1A\u5E73\u53F0\u8DEF\u7EBF\u4E0E\u65BD\u5DE5\u5C01\u8DEF\u8BB0\u5F55\u4E00\u81F4\uFF0C\u7ED5\u884C\u539F\u56E0\u6765\u81EA\u65BD\u5DE5\u5C01\u8DEF\u540E\u7684\u5730\u56FE\u5EF6\u8FDF\u3002\u672C\u6B21\u8BC1\u636E\u6709\u6548\u3002"
  onWrongEvidenceText: "A07\uFF1A\u540E\u53F0\u672A\u67E5\u8BE2\u5230\u80FD\u591F\u652F\u6301\u8BE5\u8BC1\u636E\u7684\u76F8\u5173\u8BB0\u5F55\uFF0C\u8BC1\u636E\u65E0\u6548\u3002"
  onResolvedText: "\u5DE5\u5355\u5DF2\u5173\u95ED\u3002\u7528\u6237\u8BA4\u4E3A\u7CFB\u7EDF\u6CA1\u6709\u771F\u6B63\u6838\u9A8C\u8DEF\u7EBF\u3002"
