  evidencePromptText: "\u8BF7\u4ECE\u8D44\u659901\uFF5E\u8D44\u659904\u4E2D\u9009\u62E9\u6700\u80FD\u652F\u6301\u7528\u6237\u8BC9\u6C42\u7684\u8BC1\u636E\u3002"
  hasEvidence: 1
  evidenceId: E_ROUTE_CONSTRUCTION
  correctEvidenceIndex: 3
  onSaveEvidenceText: "A07\uFF1A\u5E73\u53F0\u8DEF\u7EBF\u4E0E\u65BD\u5DE5\u5C01\u8DEF\u8BB0\u5F55\u4E00\u81F4\uFF0C\u7ED5\u884C\u539F\u56E0\u6765\u81EA\u65BD\u5DE5\u5C01\u8DEF\u540E\u7684\u5730\u56FE\u5EF6\u8FDF\u3002\u672C\u6B21\u8BC1\u636E\u6709\u6548\u3002"
