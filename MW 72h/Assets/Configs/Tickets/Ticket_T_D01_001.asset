  userMessage: "\u6211\u6309\u7CFB\u7EDF\u8DEF\u7EBF\u8D70\uFF0C\u6700\u540E\u8FD8\u6263\u4E86
    60 \u5757\u3002\u90A3\u6BB5\u8DEF\u660E\u660E\u5C01\u4E86\uFF0C\u662F\u7CFB\u7EDF\u8BA9\u6211\u7ED5\u884C\u3002"
