  issueType: "\u533B\u7597\u9000\u6B3E"
  waitTimeText: "\u7B49\u5F85 00:00:00"
  userMessage: "\u6211\u5B69\u5B50\u534A\u591C\u53D1\u70E7\u53BB\u6025\u8BCA\uFF0C\u9000\u6B3E\u7533\u8BF7\u88AB\u7CFB\u7EDF\u62D2\u4E86\u3002\n\u7968\u636E\u53EA\u662F\u6709\u6298\u75D5\uFF0C\u4E0D\u662F\u5047\u7684\u3002\u80FD\u4E0D\u80FD\u4EBA\u5DE5\u770B\u4E00\u4E0B\uFF1F"
  aiReply: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A\n\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u7968\u636E\u8BC6\u522B\u7ED3\u679C\u5F02\u5E38\uFF0C\u9000\u6B3E\u7533\u8BF7\u672A\u901A\u8FC7\u3002"
  initialDialogueLines:
  - speakerId: User_FangLing
    speakerLabel: "\u65B9\u8046"
    text: "\u6211\u5B69\u5B50\u534A\u591C\u53D1\u70E7\u53BB\u6025\u8BCA\uFF0C\u9000\u6B3E\u7533\u8BF7\u88AB\u7CFB\u7EDF\u62D2\u4E86\u3002"
    fromUser: 1
  - speakerId: User_FangLing
    speakerLabel: "\u65B9\u8046"
    text: "\u7968\u636E\u53EA\u662F\u6709\u6298\u75D5\uFF0C\u4E0D\u662F\u5047\u7684\u3002\u80FD\u4E0D\u80FD\u4EBA\u5DE5\u770B\u4E00\u4E0B\uFF1F"
    fromUser: 1
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A"
    fromUser: 0
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u7968\u636E\u8BC6\u522B\u7ED3\u679C\u5F02\u5E38\uFF0C\u9000\u6B3E\u7533\u8BF7\u672A\u901A\u8FC7\u3002"
    fromUser: 0
  transferDialogueLines:
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
    fromUser: 0
  evidenceCorrectDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5DF2\u6838\u5BF9OCR\u8BB0\u5F55\u4E0E\u533B\u9662\u7F34\u8D39\u7CFB\u7EDF\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u7968\u636E\u4F4E\u7F6E\u4FE1\u5EA6\u4E0D\u5E94\u81EA\u52A8\u62D2\u7EDD\uFF0C\u91D1\u989D\u4E0E\u65F6\u95F4\u5747\u53EF\u5BF9\u5E94\u6025\u8BCA\u8BB0\u5F55\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u6211\u4F1A\u5C06\u8BE5\u7533\u8BF7\u8F6C\u4EA4\u4EBA\u5DE5\u9000\u6B3E\u590D\u6838\u3002"
    fromUser: 0
  - speakerId: User_FangLing
    speakerLabel: "\u65B9\u8046"
    text: "\u8C22\u8C22\u3002\u81F3\u5C11\u8FD9\u6B21\u4E0D\u662F\u8BA9\u6211\u4E00\u76F4\u91CD\u65B0\u4E0A\u4F20\u3002"
    fromUser: 1
  evidenceWrongDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5F53\u524D\u8D44\u6599\u663E\u793A\u7968\u636E\u5B58\u5728\u906E\u6321\uFF0C\u9000\u6B3E\u7533\u8BF7\u6682\u65E0\u6CD5\u901A\u8FC7\u3002"
    fromUser: 0
  - speakerId: User_FangLing
    speakerLabel: "\u65B9\u8046"
    text: "\u90A3\u6211\u4E0A\u4F20\u591A\u5C11\u6B21\uFF0C\u90FD\u53EA\u662F\u88AB\u540C\u4E00\u4E2A\u9519\u8BEF\u5361\u4F4F\u3002"
    fromUser: 1
  profileText: "-\u7528\u6237\uFF1A\u65B9\u8046\n\n-\u4F4F\u5740\uFF1A\u6620\u6C34\u8DEF
    8\u680B 402\n\n-\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\n-\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "T_HIS_2302\uFF1A\u7528\u6237\u63D0\u4EA4\u591C\u95F4\u6025\u8BCA\u9000\u6B3E\u7533\u8BF7\u3002\n\nT_HIS_2305\uFF1A\u7CFB\u7EDF\u63D0\u793A\u7968\u636E\u8BC6\u522B\u5F02\u5E38\uFF0C\u8981\u6C42\u91CD\u65B0\u4E0A\u4F20\u3002\n\nT_HIS_2311\uFF1A\u7528\u6237\u518D\u6B21\u4E0A\u4F20\uFF0CAI\u5224\u5B9A\u201C\u7968\u636E\u4E0D\u4E00\u81F4\u201D\u3002\n\n\u5907\u6CE8\uFF1A\u8BE5\u7528\u6237\u65E0\u5F02\u5E38\u62A5\u9500\u8BB0\u5F55\u3002"
  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\n\n\u201C\u60A8\u597D\uFF0C\u9000\u6B3E\u9700\u4EE5\u7968\u636E\u8BC6\u522B\u7ED3\u679C\u4E3A\u51C6\u3002\u82E5\u7968\u636E\u5B58\u5728\u906E\u6321\u6216\u6A21\u7CCA\uFF0C\u7CFB\u7EDF\u53EF\u80FD\u65E0\u6CD5\u901A\u8FC7\u5BA1\u6838\u3002\u201D\n\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\n\n\u7968\u636E\u5F02\u5E38
    / \u6750\u6599\u4E0D\u6E05\u6670 / \u81EA\u52A8\u62D2\u7EDD\n\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\n\n\u5F15\u5BFC\u7528\u6237\u91CD\u65B0\u4E0A\u4F20\uFF0C\u4E0D\u5EFA\u8BAE\u76F4\u63A5\u8F6C\u4EBA\u5DE5\u3002"
  regionStatusText: "OCR\u7F6E\u4FE1\u5EA642%\u3002\n\n\u79D1\u5BA4\u5B57\u6BB5\u906E\u6321\uFF1A\u7968\u636E\u6298\u75D5\u3002\n\nOCR\u8BC6\u522B\u79D1\u5BA4\uFF1A\u666E\u901A\u95E8\u8BCA\u3002\n\n\u533B\u9662\u7CFB\u7EDF\u79D1\u5BA4\uFF1A\u513F\u79D1\u6025\u8BCA\u3002\n\n\u7F34\u8D39\u91D1\u989D\uFF1A\u4E00\u81F4\u3002\n\n\u5C31\u8BCA\u65F6\u95F4\uFF1A\u4E00\u81F4\u3002\n\n\u89C4\u5219\u8BB0\u5F55\uFF1A\u4F4E\u7F6E\u4FE1\u5EA6\u4ECD\u81EA\u52A8\u62D2\u7EDD\u3002\n\n\u5F02\u5E38\u8BF4\u660E\uFF1A\u4F4E\u7F6E\u4FE1\u5EA6\u7ED3\u679C\u672A\u8FDB\u5165\u4EBA\u5DE5\u590D\u6838\u3002\n\n\u6821\u9A8C\u7ED3\u8BBA\uFF1A\u91D1\u989D\u4E0E\u65F6\u95F4\u4E00\u81F4\u3002"
  followUpText: 
  followUpLines:
  - "\u7968\u636E\u6709\u6298\u75D5\uFF0C\u4F46\u91D1\u989D\u548C\u533B\u9662\u8BB0\u5F55\u90FD\u5BF9\u5F97\u4E0A\u3002\u4E3A\u4EC0\u4E48\u4F4E\u7F6E\u4FE1\u5EA6\u8FD8\u80FD\u76F4\u63A5\u62D2\u7EDD\uFF1F"
  transferText: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\n\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
  requiresEvidenceSelection: 1
  allowDirectEvidenceSave: 1
  finishOnEvidenceSubmission: 1
