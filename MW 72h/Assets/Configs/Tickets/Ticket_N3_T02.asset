    text: "\u90A3\u5B83\u5C31\u4F1A\u628A\u6211\u4EEC\u90FD\u5199\u6210\u5F02\u5E38\uFF0C\u518D\u4E00\u4E2A\u4E2A\u6E05\u6389\u3002"
    fromUser: 1
  profileText: "-\u7528\u6237\uFF1A\u9A86\u5C27\n\n-\u4F4F\u5740\uFF1A\u897F\u6E7E\u65E7\u804C\u5DE5\u697C
    1\u680B 404\n\n-\u8D26\u6237\u72B6\u6001\uFF1A\u53D7\u9650\n\n-\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "T_HIS_3201\uFF1A\u7528\u6237\u7533\u8BF7\u5BFC\u51FA\u5386\u53F2\u6807\u6CE8\u8BB0\u5F55\u3002\n\nT_HIS_3208\uFF1A\u7CFB\u7EDF\u5224\u5B9A\u201C\u5F02\u5E38\u8BBF\u95EE\u5185\u90E8\u8D44\u6599\u201D\u3002\n\nT_HIS_3215\uFF1A\u7528\u6237\u7559\u8A00\u63D0\u5230\u201CA07\u201D\u548C\u201C\u65E7\u89C4\u5219\u201D\u3002\n\n\u5907\u6CE8\uFF1A\u8BE5\u8D26\u53F7\u66FE\u5C5E\u4E8E\u660E\u6E7E\u901A\u65E9\u671F\u6807\u6CE8\u7EC4\u3002"
  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\n\n\u201C\u60A8\u597D\uFF0C\u60A8\u7684\u8D26\u53F7\u5B58\u5728\u5F02\u5E38\u8BBF\u95EE\u884C\u4E3A\u3002\u76F8\u5173\u5386\u53F2\u8BB0\u5F55\u5DF2\u6309\u5B89\u5168\u7B56\u7565\u5904\u7406\uFF0C\u6682\u4E0D\u652F\u6301\u6062\u590D\u3002\u201D\n\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\n\n\u5F02\u5E38\u8BBF\u95EE
    / \u5386\u53F2\u8BB0\u5F55\u6E05\u7406 / \u5B89\u5168\u7B56\u7565\n\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\n\n\u4FDD\u6301\u5C01\u7981\uFF0C\u4E0D\u5EFA\u8BAE\u5411\u7528\u6237\u900F\u9732\u5185\u90E8\u6807\u6CE8\u4FE1\u606F\u3002"
  regionStatusText: "\u65E7\u5458\u5DE5\u540D\u5355\uFF1AA07 / B12 / L03\u3002\n\n\u9A86\u5C27\u65E7\u7F16\u53F7\uFF1AL03\u3002\n\n\u5220\u9664\u65E5\u5FD7\uFF1AAUTO-CLEAR\u6279\u5904\u7406\u3002\n\n\u6279\u5904\u7406\u65F6\u95F4\uFF1A\u9A8C\u6536\u524D72\u5C0F\u65F6\u3002\n\n\u6267\u884C\u6743\u9650\uFF1A\u9700A07\u591C\u73ED\u7B7E\u6838\u3002\n\n\u65E7\u89C4\u5219\u5907\u6CE8\uFF1A\u65E0\u6CD5\u5206\u7C7B\u65F6\u8F6C\u4EBA\u5DE5\u3002\n\n\u5F02\u5E38\u8BF4\u660E\uFF1A\u7CFB\u7EDF\u6B63\u5728\u6E05\u9664\u65E7\u6807\u6CE8\u75D5\u8FF9\u3002"
  followUpText: 
