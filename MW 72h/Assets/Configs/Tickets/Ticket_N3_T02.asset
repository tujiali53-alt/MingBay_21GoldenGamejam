    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5DF2\u6838\u5BF9\u65E7\u5458\u5DE5\u540D\u5355\u4E0E\u5220\u9664\u65E5\u5FD7\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u8BE5\u8D26\u53F7\u5C5E\u4E8E\u65E9\u671F\u6807\u6CE8\u7EC4\uFF0C\u8BB0\u5F55\u5220\u9664\u6765\u81EAAUTO-CLEAR\u6279\u5904\u7406\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u6211\u4F1A\u6062\u590D\u65E7\u6863\u6848\u7D22\u5F15\uFF0C\u5E76\u4FDD\u7559\u8BE5\u6279\u5904\u7406\u8BB0\u5F55\u3002"
    fromUser: 0
  - speakerId: User_LuoYao
    speakerLabel: "\u9A86\u5C27"
    text: "\u4F60\u7EC8\u4E8E\u770B\u5230\u4E86\u3002\u5B83\u4E0D\u662F\u5FD8\u4E86\u6211\u4EEC\uFF0C\u662F\u5728\u6E05\u6389\u6211\u4EEC\u3002"
    fromUser: 1
  evidenceWrongDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5F53\u524D\u8D44\u6599\u663E\u793A\u8D26\u53F7\u5B58\u5728\u5F02\u5E38\u8BBF\u95EE\uFF0C\u5386\u53F2\u8BB0\u5F55\u6682\u4E0D\u652F\u6301\u6062\u590D\u3002"
