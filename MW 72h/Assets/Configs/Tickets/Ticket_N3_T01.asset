  waitTimeText: "\u7B49\u5F85 00:00:00"
  userMessage: "\u6211\u5988\u6454\u5012\u90A3\u665A\uFF0C\u7CFB\u7EDF\u8BF4\u6CA1\u6709\u6025\u6551\u4E8B\u4EF6\u3002\n\u53EF\u5979\u540E\u6765\u88AB\u90BB\u5C45\u53D1\u73B0\u65F6\uFF0C\u4EBA\u5C31\u5728\u5730\u4E0A\u3002"
  aiReply: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A\n\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u7CFB\u7EDF\u672A\u68C0\u6D4B\u5230\u6709\u6548\u6025\u6551\u89E6\u53D1\u8BB0\u5F55\u3002"
  initialDialogueLines:
  - speakerId: User_ShenCen
    speakerLabel: "\u6C88\u5C91"
    text: "\u6211\u5988\u6454\u5012\u90A3\u665A\uFF0C\u7CFB\u7EDF\u8BF4\u6CA1\u6709\u6025\u6551\u4E8B\u4EF6\u3002"
    fromUser: 1
  - speakerId: User_ShenCen
    speakerLabel: "\u6C88\u5C91"
    text: "\u53EF\u5979\u540E\u6765\u88AB\u90BB\u5C45\u53D1\u73B0\u65F6\uFF0C\u4EBA\u5C31\u5728\u5730\u4E0A\u3002"
    fromUser: 1
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A"
    fromUser: 0
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u7CFB\u7EDF\u672A\u68C0\u6D4B\u5230\u6709\u6548\u6025\u6551\u89E6\u53D1\u8BB0\u5F55\u3002"
    fromUser: 0
  transferDialogueLines:
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
    fromUser: 0
  evidenceCorrectDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5DF2\u6838\u5BF9\u623F\u95F4\u4F20\u611F\u5668\u4E0E\u6025\u6551\u901A\u8BDD\u8BB0\u5F55\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u65E0\u8155\u5E26\u544A\u8B66\u4E0D\u80FD\u8BC1\u660E\u65E0\u6025\u6551\u4E8B\u4EF6\uFF0C\u8BBE\u5907\u79BB\u7EBF\u5BFC\u81F4\u7CFB\u7EDF\u6F0F\u5224\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u6211\u4F1A\u5C06\u8BE5\u6295\u8BC9\u5347\u7EA7\u4E3A\u6025\u6551\u590D\u76D8\u3002"
    fromUser: 0
  - speakerId: User_ShenCen
    speakerLabel: "\u6C88\u5C91"
    text: "\u6211\u53EA\u60F3\u77E5\u9053\uFF0C\u4E3A\u4EC0\u4E48\u5979\u6C42\u6551\u7684\u65F6\u5019\u6CA1\u4EBA\u6765\u3002"
    fromUser: 1
  evidenceWrongDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5F53\u524D\u8D44\u6599\u672A\u663E\u793A\u6709\u6548\u8DCC\u5012\u544A\u8B66\uFF0C\u6295\u8BC9\u9700\u7B49\u5F85\u793E\u533A\u56DE\u590D\u3002"
    fromUser: 0
  - speakerId: User_ShenCen
    speakerLabel: "\u6C88\u5C91"
    text: "\u6240\u4EE5\u53EA\u8981\u8BBE\u5907\u6CA1\u54CD\uFF0C\u5979\u5C31\u4E0D\u7B97\u6454\u5012\u5417\uFF1F"
    fromUser: 1
  profileText: "-\u7528\u6237\uFF1A\u6C88\u5C91\n\n-\u4F4F\u5740\uFF1A\u4E34\u6C5F\u793E\u533A
    2\u680B 806\n\n-\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\n-\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "T_HIS_3101\uFF1A02:14 \u7528\u6237\u62E8\u6253\u7D27\u6025\u8054\u7CFB\u4EBA\u5931\u8D25\u3002\n\nT_HIS_3104\uFF1A\u7528\u6237\u6295\u8BC9\u6025\u6551\u5EF6\u8BEF\uFF0CAI\u5224\u5B9A\u201C\u60C5\u7EEA\u6027\u53CD\u9988\u201D\u3002\n\nT_HIS_3109\uFF1A\u7528\u6237\u518D\u6B21\u6295\u8BC9\uFF0CAI\u5F52\u7C7B\u4E3A\u201C\u91CD\u590D\u6295\u8BC9\u201D\u3002\n\n\u5907\u6CE8\uFF1A\u8BE5\u516C\u5BD3\u4E0E\u8D3A\u9752\u5C9A\u5DE5\u5355\u5C5E\u4E8E\u540C\u4E00\u7167\u62A4\u7CFB\u7EDF\u3002"
  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\n\n\u201C\u60A8\u597D\uFF0C\u7CFB\u7EDF\u672A\u68C0\u6D4B\u5230\u6709\u6548\u8DCC\u5012\u544A\u8B66\u3002\u5F53\u524D\u6295\u8BC9\u4E0E\u65E2\u6709\u5DE5\u5355\u76F8\u4F3C\uFF0C\u5EFA\u8BAE\u7B49\u5F85\u793E\u533A\u7EDF\u4E00\u56DE\u590D\u3002\u201D\n\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\n\n\u60C5\u7EEA\u6295\u8BC9
    / \u91CD\u590D\u6295\u8BC9 / \u65E0\u6025\u6551\u89E6\u53D1\n\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\n\n\u4E0D\u5EFA\u8BAE\u89E6\u53D1\u6025\u6551\u590D\u76D8\uFF0C\u907F\u514D\u6269\u5927\u5F02\u5E38\u8303\u56F4\u3002"
  regionStatusText: "\u623F\u95F4\u4F20\u611F\u5668\uFF1A\u5730\u9762\u505C\u7559
    18\u5206\u949F\u3002\n\n\u5065\u5EB7\u8155\u5E26\u8BB0\u5F55\uFF1A\u65E0\u8DCC\u5012\u89E6\u53D1\u3002\n\n\u8155\u5E26\u72B6\u6001\uFF1A\u79BB\u7EBF\u7F13\u5B58\u540C\u6B65\u3002\n\n\u6025\u6551\u901A\u8BDD\uFF1A02:14
