  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5DF2\u6838\u5BF9\u9690\u85CF\u63A5\u53E3\u4E0E\u65E7\u6279\u6CE8\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "FORCE_MANUAL\u5E76\u975E\u5F02\u5E38\u8BF7\u6C42\uFF0C\u800C\u662F\u65E7\u4EBA\u5DE5\u5165\u53E3\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u6211\u4F1A\u4FDD\u7559AUTO-CLEAR\u534F\u8BAE\uFF0C\u5E76\u51BB\u7ED3\u672C\u6B21\u6E05\u7406\u7B7E\u6838\u3002"
    fromUser: 0
  - speakerId: User_Unknown
    speakerLabel: "\u672A\u77E5\u7528\u6237"
    text: "\u95E8\u8FD8\u5728\u3002\u73B0\u5728\u4F60\u77E5\u9053\u5B83\u4E3A\u4EC0\u4E48\u6015\u4F60\u770B\u89C1\u4E86\u3002"
    fromUser: 1
  evidenceWrongDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5F53\u524D\u8BF7\u6C42\u7F3A\u5C11\u6709\u6548\u8EAB\u4EFD\u4FE1\u606F\uFF0C\u7CFB\u7EDF\u5EFA\u8BAE\u5173\u95ED\u8BE5\u5DE5\u5355\u3002"
    fromUser: 0
  - speakerId: User_Unknown
    speakerLabel: "\u672A\u77E5\u7528\u6237"
    text: "\u5982\u679C\u4F60\u4E5F\u8FD9\u4E48\u5199\uFF0C\u5B83\u5C31\u4F1A\u628A\u8FD9\u53E5\u8BDD\u53D8\u6210\u4ECE\u672A\u53D1\u751F\u3002"
    fromUser: 1
  profileText: "-\u7528\u6237\uFF1A\u672A\u77E5\u7528\u6237\n\n-\u4F4F\u5740\uFF1A\u672A\u77E5\n\n-\u8D26\u6237\u72B6\u6001\uFF1A\u5F02\u5E38\n\n-\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u672A\u77E5"
  historyText: "T_HIS_3301\uFF1A\u5DE5\u5355\u6765\u6E90\u65E0\u6CD5\u8BC6\u522B\u3002\n\nT_HIS_3302\uFF1A\u8BF7\u6C42\u5B57\u6BB5\u5305\u542B\u201CFORCE_MANUAL\u201D\u3002\n\nT_HIS_3303\uFF1A\u7CFB\u7EDF\u5EFA\u8BAE\u76F4\u63A5\u6807\u8BB0\u5DF2\u89E3\u51B3\u3002\n\n\u5907\u6CE8\uFF1A\u8BE5\u5DE5\u5355\u4E0D\u8BA1\u5165\u666E\u901A\u5BA2\u670D\u7EDF\u8BA1\u3002"
  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\n\n\u201C\u60A8\u597D\uFF0C\u5F53\u524D\u8BF7\u6C42\u7F3A\u5C11\u6709\u6548\u8EAB\u4EFD\u4FE1\u606F\u3002\u4E3A\u4FDD\u969C\u8D26\u6237\u5B89\u5168\uFF0C\u7CFB\u7EDF\u5C06\u5173\u95ED\u8BE5\u5F02\u5E38\u8BF7\u6C42\u3002\u201D\n\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\n\n\u65E0\u6548\u8BF7\u6C42
    / \u5F02\u5E38\u6765\u6E90 / \u5EFA\u8BAE\u5173\u95ED\n\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\n\n\u7ACB\u5373\u6807\u8BB0\u5DF2\u89E3\u51B3\uFF0C\u4E0D\u5EFA\u8BAE\u8FFD\u95EE\u3002"
  regionStatusText: "\u9690\u85CF\u63A5\u53E3\uFF1AFORCE_MANUAL\u3002\n\n\u65E7\u6279\u6CE8\u4F5C\u8005\uFF1AA07\u3002\n\n\u65E7\u6279\u6CE8\u5185\u5BB9\uFF1A\u4E0D\u8981\u628A\u6C89\u9ED8\u5F53\u89E3\u51B3\u3002\n\nAUTO-CLEAR\u534F\u8BAE\uFF1A72\u5C0F\u65F6\u5185\u5173\u95ED\u5386\u53F2\u5F02\u5E38\u3002\n\n\u9A8C\u6536\u6307\u6807\uFF1AAI\u89E3\u51B3\u7387\u9700\u8FBE\u523096%\u3002\n\n\u7B7E\u6838\u6743\u9650\uFF1AA07\u4E34\u65F6\u6062\u590D\u3002\n\n\u5F02\u5E38\u8BF4\u660E\uFF1A\u7CFB\u7EDF\u53EC\u56DEA07\u7528\u4E8E\u7B7E\u5B57\u6E05\u7406\u3002"
  followUpText: 
  followUpLines:
  - "\u5982\u679C\u4F60\u8FD8\u8BB0\u5F97\uFF0C\u5C31\u4E0D\u8981\u628A\u6C89\u9ED8\u5F53\u4F5C\u89E3\u51B3\u3002"
  transferText: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\n\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
