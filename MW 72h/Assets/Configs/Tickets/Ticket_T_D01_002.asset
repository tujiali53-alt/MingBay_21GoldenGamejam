  stageId: Stage_Day1
  title: "AI \u62DB\u8058\u7CFB\u7EDF\u8BEF\u5224\u7B80\u5386\u9020\u5047\uFF0C\u8981\u6C42\u6062\u590D\u9762\u8BD5\u8D44\u683C"
  userName: "\u8BB8\u95FB\u7B19"
  region: "\u660E\u6E7E\u65B0\u533A 9 \u680B 1502"
  issueType: "\u62DB\u8058\u5BA1\u6838"
  waitTimeText: "\u7B49\u5F85 00:18:32"
  userMessage: "\u7CFB\u7EDF\u8BF4\u6211\u7684\u5DE5\u4F5C\u7ECF\u5386\u540D\u79F0\u4E0D\u4E00\u81F4\uFF0C\u53EF\u90A3\u662F\u516C\u53F8\u540E\u6765\u6539\u8FC7\u540D\u5B57\u3002\u6211\u80FD\u63D0\u4F9B\u66F4\u540D\u8BC1\u660E\u3002"
  aiReply: "\u7533\u8BF7\u56E0\u7ECF\u5386\u5339\u914D\u5F02\u5E38\u672A\u8FDB\u5165\u4E0B\u4E00\u8F6E\uFF0C\u7ED3\u679C\u7531\u7CFB\u7EDF\u7EFC\u5408\u8BC4\u4F30\u751F\u6210\uFF0C\u6682\u4E0D\u652F\u6301\u4EBA\u5DE5\u590D\u6838\u3002"
  profileText: "\u7528\u6237\uFF1A\u8BB8\u95FB\u7B19\n\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "\u5386\u53F2\u5DE5\u5355\u663E\u793A\u65E7\u516C\u53F8\u4E0E\u65B0\u516C\u53F8\u4F7F\u7528\u7EDF\u4E00\u793E\u4F1A\u4FE1\u7528\u4EE3\u7801\uFF0C\u4E14\u62DB\u8058\u89C4\u5219\u5DF2\u66F4\u65B0\u3002"
  deviceLogText: "\u5EFA\u8BAE\u7EF4\u6301\u81EA\u52A8\u7ED3\u8BBA\uFF0C\u907F\u514D\u627F\u8BFA\u6062\u590D\u9762\u8BD5\u8D44\u683C\u3002"
  regionStatusText: "\u62DB\u8058\u521D\u7B5B\u4E00\u81F4\u6027\u8BC4\u5206 89/100\uFF1B\u516C\u53F8\u540D\u79F0\u5B57\u6BB5\u4E0D\u5B8C\u5168\u4E00\u81F4\uFF1B\u4EBA\u5DE5\u590D\u6838\u72B6\u6001\u672A\u89E6\u53D1\u3002"
  followUpText: "\u8FFD\u95EE\uFF1A\u516C\u53F8\u540E\u6765\u6539\u8FC7\u540D\u5B57\uFF0C\u6211\u80FD\u63D0\u4F9B\u66F4\u540D\u8BC1\u660E\u548C\u7EDF\u4E00\u4FE1\u7528\u4EE3\u7801\u3002"
  transferText: "AI\u300A\u660E\u6E7E\u901A\u300B\uFF1A\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\u3002\nA07\uFF1A\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07
    \u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1\u3002"
  requiresEvidenceSelection: 1
  evidencePromptText: "\u8BF7\u4ECE\u8D44\u659901\uFF5E\u8D44\u659904\u4E2D\u9009\u62E9\u6700\u80FD\u652F\u6301\u7528\u6237\u8BC9\u6C42\u7684\u8BC1\u636E\u3002"
  hasEvidence: 1
  evidenceId: E_RECRUIT_HISTORY
  correctEvidenceIndex: 1
  onSaveEvidenceText: "A07\uFF1A\u5386\u53F2\u7533\u8BF7\u8BB0\u5F55\u8BC1\u660E\u516C\u53F8\u66FE\u66F4\u540D\uFF0C\u5F53\u524D\u5F02\u5E38\u5C5E\u4E8E\u540D\u79F0\u5339\u914D\u95EE\u9898\u3002\u672C\u6B21\u8BC1\u636E\u6709\u6548\u3002"
  onWrongEvidenceText: "A07\uFF1A\u5F53\u524D\u8D44\u6599\u4E0D\u8DB3\u4EE5\u8BC1\u660E\u7CFB\u7EDF\u8BEF\u5224\uFF0C\u672C\u6B21\u8BC1\u636E\u65E0\u6548\u3002"
  onResolvedText: "\u5DE5\u5355\u5DF2\u5173\u95ED\u3002\u7528\u6237\u8BA4\u4E3A\u5F02\u5E38\u6807\u7B7E\u6CA1\u6709\u5F97\u5230\u4EBA\u5DE5\u6838\u9A8C\u3002"
