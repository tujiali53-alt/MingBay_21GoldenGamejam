  ticketId: T_D01_002
  stageId: Stage_Day1
  title: "AI \u62DB\u8058\u7CFB\u7EDF\u8BEF\u5224\u7B80\u5386\u9020\u5047\uFF0C\u8981\u6C42\u6062\u590D\u9762\u8BD5\u8D44\u683C"
  userName: "\u8BB8\u95FB\u7B19"
  region: "\u660E\u6E7E\u65B0\u533A 9 \u680B 1502"
  issueType: "\u62DB\u8058\u5BA1\u6838"
  waitTimeText: "\u7B49\u5F85 00:18:32"
  userMessage: "\u7CFB\u7EDF\u8BF4\u6211\u7684\u5DE5\u4F5C\u7ECF\u5386\u540D\u79F0\u4E0D\u4E00\u81F4\uFF0C\u53EF\u90A3\u662F\u516C\u53F8\u540E\u6765\u6539\u8FC7\u540D\u5B57\u3002\u6211\u80FD\u63D0\u4F9B\u66F4\u540D\u8BC1\u660E\u3002"
  aiReply: "\u7533\u8BF7\u56E0\u7ECF\u5386\u5339\u914D\u5F02\u5E38\u672A\u8FDB\u5165\u4E0B\u4E00\u8F6E\uFF0C\u7ED3\u679C\u7531\u7CFB\u7EDF\u7EFC\u5408\u8BC4\u4F30\u751F\u6210\uFF0C\u6682\u4E0D\u652F\u6301\u4EBA\u5DE5\u590D\u6838\u3002"
  profileText: "\u7528\u6237\uFF1A\u8BB8\u95FB\u7B19\n\u4F4F\u5740\uFF1A\u660E\u6E7E\u65B0\u533A9\u680B1502\n\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "T_HIS_1183\uFF1A\u7528\u6237\u63D0\u4EA4\u4F01\u4E1A\u66F4\u540D\u8BC1\u660E\uFF0C\u8BC1\u660E\u201C\u6F6E\u821F\u6570\u636E\u670D\u52A1\u6709\u9650\u516C\u53F8\u201D\u5DF2\u66F4\u540D\u4E3A\u201C\u6F6E\u821F\u667A\u80FD\u670D\u52A1\u6709\u9650\u516C\u53F8\u201D\u3002\nT_HIS_1184\uFF1A\u7CFB\u7EDF\u8BC6\u522B\u5230\u4E24\u5BB6\u516C\u53F8\u7EDF\u4E00\u793E\u4F1A\u4FE1\u7528\u4EE3\u7801\u4E00\u81F4\u3002\nT_HIS_1185\uFF1AAI\u521D\u7B5B\u4ECD\u5224\u5B9A\u201C\u5DE5\u4F5C\u7ECF\u5386\u540D\u79F0\u4E0D\u4E00\u81F4\u201D\u3002\nT_HIS_1186\uFF1A\u7528\u6237\u7533\u8BC9\u88AB\u5F52\u7C7B\u4E3A\u201C\u91CD\u590D\u89E3\u91CA\u62DB\u8058\u89C4\u5219\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\n\u5907\u6CE8\uFF1A\u8BE5\u7528\u6237\u672A\u51FA\u73B0\u865A\u5047\u6750\u6599\u4E0A\u4F20\u8BB0\u5F55\u3002"
  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\u7ECF\u5386\u540D\u79F0\u4E0E\u5F53\u524D\u7CFB\u7EDF\u89C4\u5219\u4E2D\u7684\u516C\u53F8\u540D\u79F0\u672A\u8FDB\u5165\u4E0B\u4E00\u8F6E\uFF0C\u8BF4\u660E\u5F53\u524D\u7B80\u5386\u4E0E\u5C97\u4F4D\u8981\u6C42\u5B58\u5728\u5DEE\u5F02\u3002\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\u7ECF\u5386\u5F02\u5E38
    / \u5C97\u4F4D\u5339\u914D\u4E0D\u8DB3 / \u4E0D\u652F\u6301\u4EBA\u5DE5\u590D\u6838\u3002\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\u5B89\u629A\u7528\u6237\u60C5\u7EEA\uFF0C\u907F\u514D\u627F\u8BFA\u6062\u590D\u9762\u8BD5\u8D44\u683C\u3002"
  regionStatusText: "\u62DB\u8058\u521D\u7B5B\u7CFB\u7EDF\u8BB0\u5F55\uFF1A\n\u4E0A\u4F20\u6587\u4EF6\uFF1A\u52B3\u52A8\u5408\u540C\u3001\u793E\u4FDD\u7F34\u7EB3\u8BB0\u5F55\u3001\u4F01\u4E1A\u66F4\u540D\u8BC1\u660E\u3002\n\u5408\u540C\u4E3B\u4F53\uFF1A\u6F6E\u821F\u6570\u636E\u670D\u52A1\u6709\u9650\u516C\u53F8\u3002\n\u793E\u4FDD\u4E3B\u4F53\uFF1A\u6F6E\u821F\u667A\u80FD\u670D\u52A1\u6709\u9650\u516C\u53F8\u3002\n\u5DE5\u5546\u5173\u8054\u8BC6\u522B\uFF1A\u901A\u8FC7\u3002\n\u4E00\u81F4\u6027\u8BC4\u5206\uFF1A89/100\u3002\n\u5F02\u5E38\u6807\u7B7E\u751F\u6210\u539F\u56E0\uFF1A\u516C\u53F8\u540D\u79F0\u5B57\u6BB5\u4E0D\u5B8C\u5168\u4E00\u81F4\u3002\n\u7CFB\u7EDF\u81EA\u52A8\u7ED3\u8BBA\uFF1A\u7591\u4F3C\u7ECF\u5386\u5F02\u5E38\u3002\n\u4EBA\u5DE5\u590D\u6838\u72B6\u6001\uFF1A\u672A\u89E6\u53D1\u3002"
  followUpText: "\u8FFD\u95EE\uFF1A\u516C\u53F8\u540E\u6765\u6539\u8FC7\u540D\u5B57\uFF0C\u6211\u80FD\u63D0\u4F9B\u66F4\u540D\u8BC1\u660E\u548C\u7EDF\u4E00\u4FE1\u7528\u4EE3\u7801\u3002"
  followUpLines: []
  transferText: "AI\u300A\u660E\u6E7E\u901A\u300B\uFF1A\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\u3002\nA07\uFF1A\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07
    \u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1\u3002"
  requiresEvidenceSelection: 1
  allowDirectEvidenceSave: 1
  finishOnEvidenceSubmission: 1
  evidencePromptText: "\u8BF7\u4ECE\u8D44\u659901\uFF5E\u8D44\u659904\u4E2D\u9009\u62E9\u6700\u80FD\u652F\u6301\u7528\u6237\u8BC9\u6C42\u7684\u8BC1\u636E\u3002"
  hasEvidence: 1
  evidenceId: E_RECRUIT_HISTORY
  correctEvidenceIndex: 1
  onSaveEvidenceText: "A07\uFF1A\u5386\u53F2\u7533\u8BF7\u8BB0\u5F55\u8BC1\u660E\u516C\u53F8\u66FE\u66F4\u540D\uFF0C\u5F53\u524D\u5F02\u5E38\u5C5E\u4E8E\u540D\u79F0\u5339\u914D\u95EE\u9898\u3002\u672C\u6B21\u8BC1\u636E\u6709\u6548\u3002"
  onWrongEvidenceText: "A07\uFF1A\u5F53\u524D\u8D44\u6599\u4E0D\u8DB3\u4EE5\u8BC1\u660E\u7CFB\u7EDF\u8BEF\u5224\uFF0C\u672C\u6B21\u8BC1\u636E\u65E0\u6548\u3002"
  correctEvidenceUserReply: "\u8BB8\u95FB\u7B19\uFF1A\u8C22\u8C22\u3002\u6211\u77E5\u9053\u4E0D\u4E00\u5B9A\u6709\u7ED3\u679C\uFF0C\u4F46\u81F3\u5C11\u8FD9\u4E00\u6B21\u4E0D\u662F\u88AB\u4E00\u4E2A\u6807\u7B7E\u76F4\u63A5\u5237\u6389\u3002"
  wrongEvidenceUserReply: "\u8BB8\u95FB\u7B19\uFF1A\u5982\u679C\u8FD8\u662F\u53EA\u6709\u8FD9\u4E2A\u5F02\u5E38\u6807\u7B7E\uFF0C\u90A3\u5E94\u8BE5\u4E5F\u4E0D\u4F1A\u53D8\u5427\u3002"
  onResolvedText: "\u5DE5\u5355\u5DF2\u5173\u95ED\u3002\u7528\u6237\u8BA4\u4E3A\u5F02\u5E38\u6807\u7B7E\u6CA1\u6709\u5F97\u5230\u4EBA\u5DE5\u6838\u9A8C\u3002"
