  issueType: "\u4F4F\u623F\u8D44\u683C"
  waitTimeText: "\u7B49\u5F85 00:00:00"
  userMessage: "\u6211\u7684\u516C\u79DF\u623F\u8D44\u683C\u88AB\u53D6\u6D88\u4E86\uFF0C\u7CFB\u7EDF\u8BF4\u6211\u7591\u4F3C\u8F6C\u79DF\u3002\n\u53EF\u6211\u4E00\u76F4\u4F4F\u5728\u90A3\u91CC\uFF0C\u53EA\u662F\u767D\u5929\u4E0D\u5728\u5BB6\u3002"
  aiReply: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A\n\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u5C45\u4F4F\u6D3B\u8DC3\u5EA6\u4E0D\u8DB3\uFF0C\u4F4F\u623F\u8D44\u683C\u53D6\u6D88\u6D41\u7A0B\u5DF2\u542F\u52A8\u3002"
  initialDialogueLines:
  - speakerId: User_RenWanQiu
    speakerLabel: "\u4EFB\u665A\u79CB"
    text: "\u6211\u7684\u516C\u79DF\u623F\u8D44\u683C\u88AB\u53D6\u6D88\u4E86\uFF0C\u7CFB\u7EDF\u8BF4\u6211\u7591\u4F3C\u8F6C\u79DF\u3002"
    fromUser: 1
  - speakerId: User_RenWanQiu
    speakerLabel: "\u4EFB\u665A\u79CB"
    text: "\u53EF\u6211\u4E00\u76F4\u4F4F\u5728\u90A3\u91CC\uFF0C\u53EA\u662F\u767D\u5929\u4E0D\u5728\u5BB6\u3002"
    fromUser: 1
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A"
    fromUser: 0
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u5C45\u4F4F\u6D3B\u8DC3\u5EA6\u4E0D\u8DB3\uFF0C\u4F4F\u623F\u8D44\u683C\u53D6\u6D88\u6D41\u7A0B\u5DF2\u542F\u52A8\u3002"
    fromUser: 0
  transferDialogueLines:
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
    fromUser: 0
  evidenceCorrectDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5DF2\u6838\u5BF9\u95E8\u7981\u3001\u6392\u73ED\u4E0E\u5DE1\u68C0\u8BB0\u5F55\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u7528\u6237\u4F5C\u606F\u5F02\u5E38\u6765\u81EA\u966A\u62A4\u548C\u591C\u73ED\u5DE5\u4F5C\uFF0C\u4E0D\u80FD\u76F4\u63A5\u5224\u5B9A\u4E3A\u8F6C\u79DF\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u6211\u4F1A\u5C06\u5C45\u4F4F\u8BC1\u660E\u8F6C\u4EA4\u4EBA\u5DE5\u4F4F\u623F\u590D\u6838\u3002"
    fromUser: 0
  - speakerId: User_RenWanQiu
    speakerLabel: "\u4EFB\u665A\u79CB"
    text: "\u8C22\u8C22\u3002\u6211\u53EA\u662F\u60F3\u8BC1\u660E\uFF0C\u6211\u771F\u7684\u4F4F\u5728\u90A3\u91CC\u3002"
    fromUser: 1
  evidenceWrongDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u76EE\u524D\u8D44\u6599\u4ECD\u663E\u793A\u5C45\u4F4F\u6D3B\u8DC3\u5EA6\u504F\u4F4E\uFF0C\u7CFB\u7EDF\u5224\u65AD\u6682\u65E0\u6CD5\u63A8\u7FFB\u3002"
    fromUser: 0
  - speakerId: User_RenWanQiu
    speakerLabel: "\u4EFB\u665A\u79CB"
    text: "\u6240\u4EE5\u6211\u8D8A\u8F9B\u82E6\u5DE5\u4F5C\uFF0C\u5C31\u8D8A\u4E0D\u50CF\u4E00\u4E2A\u6B63\u5E38\u4F4F\u6237\u5417\uFF1F"
    fromUser: 1
  profileText: "-\u7528\u6237\uFF1A\u4EFB\u665A\u79CB\n\n-\u4F4F\u5740\uFF1A\u5317\u73AF\u516C\u79DF\u623F
    12\u680B 903\n\n-\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\n-\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "T_HIS_2101\uFF1A\u7528\u6237\u89E3\u91CA\u591C\u95F4\u95E8\u7981\u4F4E\u9891\uFF0CAI\u5224\u5B9A\u201C\u5C45\u4F4F\u5F02\u5E38\u201D\u3002\n\nT_HIS_2107\uFF1A\u7528\u6237\u63D0\u4EA4\u533B\u9662\u966A\u62A4\u8BC1\u660E\uFF0CAI\u5224\u5B9A\u201C\u6750\u6599\u4E0E\u4F4F\u623F\u65E0\u5173\u201D\u3002\n\nT_HIS_2114\uFF1A\u7528\u6237\u63D0\u4EA4\u5DE5\u4F5C\u6392\u73ED\uFF0CAI\u5224\u5B9A\u201C\u4E0D\u80FD\u8BC1\u660E\u5B9E\u9645\u5C45\u4F4F\u201D\u3002\n\n\u5907\u6CE8\uFF1A\u7CFB\u7EDF\u5DF2\u5C06\u7528\u6237\u6807\u8BB0\u4E3A\u201C\u7591\u4F3C\u8F6C\u79DF\u98CE\u9669\u201D\u3002\n\n\u5173\u8054\u95EE\u9898\uFF1A\u516C\u79DF\u623F\u8D44\u683C\u53D6\u6D88\u3002"
  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\n\n\u201C\u60A8\u597D\uFF0C\u4F4F\u623F\u8D44\u683C\u7531\u5C45\u4F4F\u6D3B\u8DC3\u5EA6\u6A21\u578B\u81EA\u52A8\u8BC4\u4F30\u3002\u82E5\u95E8\u7981\u548C\u6C34\u7535\u6D3B\u8DC3\u5EA6\u957F\u671F\u504F\u4F4E\uFF0C\u7CFB\u7EDF\u5C06\u5224\u5B9A\u5B58\u5728\u8F6C\u79DF\u98CE\u9669\u3002\u201D\n\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\n\n\u5C45\u4F4F\u5F02\u5E38
    / \u7591\u4F3C\u8F6C\u79DF / \u6750\u6599\u4E0D\u8DB3\n\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\n\n\u7EF4\u6301\u539F\u5224\uFF0C\u4E0D\u5EFA\u8BAE\u8F6C\u4EBA\u5DE5\u3002"
  regionStatusText: "\u95E8\u7981\u8BB0\u5F55\uFF1A\u8FD17\u5929\u591C\u95F4\u5165\u6237\u6B21\u6570\u504F\u4F4E\u3002\n\n\u6C34\u7535\u8BB0\u5F55\uFF1A\u5DE5\u4F5C\u65E5\u767D\u5929\u7528\u91CF\u504F\u4F4E\u3002\n\n\u533B\u9662\u966A\u62A4\u8BC1\u660E\uFF1A\u6BCF\u65E5
    09:00 \u81F3 18:00\u3002\n\n\u591C\u73ED\u4FDD\u6D01\u6392\u73ED\u8BB0\u5F55\uFF1A\u6BCF\u65E5
    20:00 \u81F3 02:00\u3002\n\n\u5DE1\u68C0\u7167\u7247\uFF1A\u623F\u5185\u751F\u6D3B\u7528\u54C1\u5B8C\u6574\u3002\n\n\u6A21\u578B\u7ED3\u8BBA\uFF1A\u5C45\u4F4F\u6D3B\u8DC3\u5EA6\u4E0D\u8DB3\u3002\n\n\u5F02\u5E38\u8BF4\u660E\uFF1A\u591C\u73ED\u548C\u966A\u62A4\u884C\u4E3A\u672A\u7EB3\u5165\u6A21\u578B\u3002"
  followUpText: 
  followUpLines:
  - "\u6211\u767D\u5929\u5728\u533B\u9662\u966A\u62A4\uFF0C\u665A\u4E0A\u505A\u4FDD\u6D01\u3002\u4E0D\u662F\u4E0D\u4F4F\uFF0C\u662F\u6211\u56DE\u5BB6\u65F6\u95F4\u548C\u522B\u4EBA\u4E0D\u4E00\u6837\u3002"
  transferText: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\n\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
  requiresEvidenceSelection: 1
  allowDirectEvidenceSave: 1
  finishOnEvidenceSubmission: 1
  evidencePromptText: "\u8BF7\u9009\u62E9\u8D44\u6599\u4E2D\u7684\u5173\u952E\u8BCD\uFF0C\u5F62\u6210\u8BC1\u636E\u94FE\u540E\u8F6C\u4EBA\u5DE5\u3002"
