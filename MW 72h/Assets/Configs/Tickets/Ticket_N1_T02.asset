  title: "AI\u62DB\u8058\u7CFB\u7EDF\u8BEF\u5224\u7B80\u5386\u9020\u5047"
  userName: "\u8BB8\u95FB\u7B19"
  region: "\u660E\u6E7E\u65B0\u533A 9\u680B 1502"
  issueType: "\u62DB\u8058\u5BA1\u6838"
  waitTimeText: "\u7B49\u5F85 00:00:00"
  userMessage: "\u60A8\u597D\uFF0C\u6211\u60F3\u7533\u8BC9\u4E00\u4E0B\u6211\u7684\u9762\u8BD5\u8D44\u683C\u3002\u6211\u6536\u5230\u901A\u77E5\u8BF4\u6211\u7684\u7B80\u5386\u5B58\u5728\u201C\u7ECF\u5386\u5F02\u5E38\u5339\u914D\u201D\n\u53EF\u662F\u6211\u6CA1\u6709\u9020\u5047\u3002\u6211\u51C6\u5907\u8FD9\u4E2A\u5C97\u4F4D\u5F88\u4E45\u4E86\uFF0C\u80FD\u4E0D\u80FD\u5E2E\u6211\u91CD\u65B0\u5BA1\u6838\uFF1F"
  aiReply: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A\n\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u60A8\u7684\u7533\u8BF7\u56E0\u7ECF\u5386\u5339\u914D\u5F02\u5E38\u672A\u8FDB\u5165\u4E0B\u4E00\u8F6E\u3002\u8BE5\u7ED3\u679C\u7531\u7CFB\u7EDF\u7EFC\u5408\u8BC4\u4F30\u751F\u6210\uFF0C\u6682\u4E0D\u652F\u6301\u4EBA\u5DE5\u590D\u6838"
  initialDialogueLines:
  - speakerId: User_XuWenSheng
    speakerLabel: "\u8BB8\u95FB\u7B19"
    text: "\u60A8\u597D\uFF0C\u6211\u60F3\u7533\u8BC9\u4E00\u4E0B\u6211\u7684\u9762\u8BD5\u8D44\u683C\u3002\u6211\u6536\u5230\u901A\u77E5\u8BF4\u6211\u7684\u7B80\u5386\u5B58\u5728\u201C\u7ECF\u5386\u5F02\u5E38\u5339\u914D\u201D"
    fromUser: 1
  - speakerId: User_XuWenSheng
    speakerLabel: "\u8BB8\u95FB\u7B19"
    text: "\u53EF\u662F\u6211\u6CA1\u6709\u9020\u5047\u3002\u6211\u51C6\u5907\u8FD9\u4E2A\u5C97\u4F4D\u5F88\u4E45\u4E86\uFF0C\u80FD\u4E0D\u80FD\u5E2E\u6211\u91CD\u65B0\u5BA1\u6838\uFF1F"
    fromUser: 1
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A"
    fromUser: 0
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u60A8\u7684\u7533\u8BF7\u56E0\u7ECF\u5386\u5339\u914D\u5F02\u5E38\u672A\u8FDB\u5165\u4E0B\u4E00\u8F6E\u3002\u8BE5\u7ED3\u679C\u7531\u7CFB\u7EDF\u7EFC\u5408\u8BC4\u4F30\u751F\u6210\uFF0C\u6682\u4E0D\u652F\u6301\u4EBA\u5DE5\u590D\u6838"
    fromUser: 0
  transferDialogueLines:
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
    fromUser: 0
  evidenceCorrectDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5DF2\u6838\u5BF9\u5386\u53F2\u7533\u8BC9\u8BB0\u5F55\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u7528\u6237\u66FE\u63D0\u4EA4\u4F01\u4E1A\u66F4\u540D\u8BC1\u660E\uFF0C\u7CFB\u7EDF\u4E5F\u8BC6\u522B\u5230\u65E7\u516C\u53F8\u540D\u79F0\u4E0E\u65B0\u516C\u53F8\u540D\u79F0\u5B58\u5728\u5DE5\u5546\u5173\u8054\uFF0C\u4F46AI\u521D\u7B5B\u4ECD\u5C06\u5176\u6807\u8BB0\u4E3A\u201C\u7ECF\u5386\u5F02\u5E38\u201D\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u6211\u4F1A\u5C06\u8BE5\u8BB0\u5F55\u8F6C\u4EA4\u4EBA\u5DE5\u62DB\u8058\u590D\u6838\u3002"
    fromUser: 0
  - speakerId: User_XuWenSheng
    speakerLabel: "\u8BB8\u95FB\u7B19"
    text: "\u8C22\u8C22\u3002\u6211\u77E5\u9053\u4E0D\u4E00\u5B9A\u6709\u7ED3\u679C\uFF0C\u4F46\u81F3\u5C11\u8FD9\u4E00\u6B21\u4E0D\u662F\u88AB\u4E00\u4E2A\u6807\u7B7E\u76F4\u63A5\u5237\u6389\u3002\u6211\u771F\u7684\u53EA\u662F\u60F3\u8981\u4E00\u4E2A\u6B63\u5E38\u89E3\u91CA\u7684\u673A\u4F1A\u3002"
    fromUser: 1
  evidenceWrongDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u975E\u5E38\u62B1\u6B49\uFF0C\u540E\u53F0\u8FD9\u8FB9\u5E76\u672A\u67E5\u8BE2\u5230\u76F8\u5173\u6570\u636E\uFF0C\u5F53\u524D\u8D44\u6599\u663E\u793A\u7CFB\u7EDF\u5224\u5B9A\u4E3A\u7ECF\u5386\u5339\u914D\u5F02\u5E38\uFF0C\u590D\u6838\u7ED3\u679C\u9700\u7B49\u5F85\u901A\u77E5\u3002"
    fromUser: 0
  - speakerId: User_XuWenSheng
    speakerLabel: "\u8BB8\u95FB\u7B19"
    text: "\u5982\u679C\u8FD8\u662F\u53EA\u770B\u8FD9\u4E2A\u5F02\u5E38\u6807\u7B7E\uFF0C\u90A3\u5E94\u8BE5\u4E5F\u4E0D\u4F1A\u53D8\u5427\u3002"
    fromUser: 1
  profileText: "-\u7528\u6237\uFF1A\u8BB8\u95FB\u7B19\n\n-\u4F4F\u5740\uFF1A\u660E\u6E7E\u65B0\u533A
    9\u680B 1502\n\n-\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\n-\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "T_HIS_1183\uFF1A\u7528\u6237\u63D0\u4EA4\u4F01\u4E1A\u66F4\u540D\u8BC1\u660E\uFF0C\u8BC1\u660E\u201C\u6F9C\u821F\u6570\u636E\u670D\u52A1\u6709\u9650\u516C\u53F8\u201D\u5DF2\u66F4\u540D\u4E3A\u201C\u6F9C\u821F\u667A\u80FD\u670D\u52A1\u6709\u9650\u516C\u53F8\u201D\u3002\n\nT_HIS_1184\uFF1A\u7CFB\u7EDF\u8BC6\u522B\u5230\u4E24\u5BB6\u516C\u53F8\u7EDF\u4E00\u793E\u4F1A\u4FE1\u7528\u4EE3\u7801\u4E00\u81F4\u3002\n\nT_HIS_1185\uFF1AAI\u521D\u7B5B\u4ECD\u5224\u5B9A\u201C\u5DE5\u4F5C\u7ECF\u5386\u540D\u79F0\u4E0D\u4E00\u81F4\u201D\u3002\n\nT_HIS_1186\uFF1A\u7528\u6237\u7533\u8BC9\u88AB\u5F52\u7C7B\u4E3A\u201C\u91CD\u590D\u89E3\u91CA\u62DB\u8058\u89C4\u5219\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\n\n\u5907\u6CE8\uFF1A\u8BE5\u7528\u6237\u672A\u51FA\u73B0\u865A\u5047\u6750\u6599\u4E0A\u4F20\u8BB0\u5F55"
  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\n\n\u201C\u60A8\u597D\uFF0C\u62DB\u8058\u7B5B\u9009\u7ED3\u679C\u7531\u7CFB\u7EDF\u6839\u636E\u5C97\u4F4D\u5339\u914D\u89C4\u5219\u81EA\u52A8\u751F\u6210\u3002\u82E5\u60A8\u672A\u8FDB\u5165\u4E0B\u4E00\u8F6E\uFF0C\u8BF4\u660E\u5F53\u524D\u7B80\u5386\u4E0E\u5C97\u4F4D\u8981\u6C42\u5B58\u5728\u5DEE\u5F02\u3002\u201D\n\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\n\n\u7ECF\u5386\u5F02\u5E38
    / \u5C97\u4F4D\u5339\u914D\u4E0D\u8DB3 / \u4E0D\u652F\u6301\u4EBA\u5DE5\u590D\u6838\n\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\n\n\u5B89\u629A\u7528\u6237\u60C5\u7EEA\uFF0C\u907F\u514D\u627F\u8BFA\u6062\u590D\u9762\u8BD5\u8D44\u683C\u3002"
  regionStatusText: "\u62DB\u8058\u521D\u7B5B\u7CFB\u7EDF\u8BB0\u5F55\uFF1A\n\n\u4E0A\u4F20\u6587\u4EF6\uFF1A\u52B3\u52A8\u5408\u540C\u3001\u793E\u4FDD\u7F34\u7EB3\u8BB0\u5F55\u3001\u4F01\u4E1A\u66F4\u540D\u8BC1\u660E\u3002\n\n\u5408\u540C\u4E3B\u4F53\uFF1A\u6F9C\u821F\u6570\u636E\u670D\u52A1\u6709\u9650\u516C\u53F8\u3002\n\n\u793E\u4FDD\u4E3B\u4F53\uFF1A\u6F9C\u821F\u667A\u80FD\u670D\u52A1\u6709\u9650\u516C\u53F8\u3002\n\n\u5DE5\u5546\u5173\u8054\u8BC6\u522B\uFF1A\u901A\u8FC7\u3002\n\n\u4E00\u81F4\u6027\u8BC4\u5206\uFF1A89/100\u3002\n\n\u5F02\u5E38\u6807\u7B7E\u751F\u6210\u539F\u56E0\uFF1A\u516C\u53F8\u540D\u79F0\u5B57\u6BB5\u4E0D\u5B8C\u5168\u4E00\u81F4\u3002\n\n\u7CFB\u7EDF\u81EA\u52A8\u7ED3\u8BBA\uFF1A\u7591\u4F3C\u7ECF\u5386\u5F02\u5E38\u3002\n\n\u4EBA\u5DE5\u590D\u6838\u72B6\u6001\uFF1A\u672A\u89E6\u53D1\u3002"
  followUpText: "\u53EF\u662F\u6211\u7684\u5DE5\u4F5C\u7ECF\u5386\u662F\u771F\u7684\u3002\u90A3\u5BB6\u516C\u53F8\u540E\u6765\u6539\u8FC7\u540D\u5B57\uFF0C\u6211\u5408\u540C\u4E0A\u662F\u65E7\u540D\u79F0\uFF0C\u793E\u4FDD\u8BB0\u5F55\u91CC\u662F\u65B0\u540D\u79F0\u3002\n\u6211\u4E0A\u4F20\u4E86\u8BC1\u660E\uFF0C\u4F46\u7CFB\u7EDF\u8FD8\u662F\u8BF4\u201C\u4E0D\u4E00\u81F4\u201D\u3002\u6211\u53EA\u662F\u5E0C\u671B\u6709\u4EBA\u771F\u7684\u770B\u4E00\u773C\u3002"
  followUpLines:
  - "\u53EF\u662F\u6211\u7684\u5DE5\u4F5C\u7ECF\u5386\u662F\u771F\u7684\u3002\u90A3\u5BB6\u516C\u53F8\u540E\u6765\u6539\u8FC7\u540D\u5B57\uFF0C\u6211\u5408\u540C\u4E0A\u662F\u65E7\u540D\u79F0\uFF0C\u793E\u4FDD\u8BB0\u5F55\u91CC\u662F\u65B0\u540D\u79F0\u3002\n\u6211\u4E0A\u4F20\u4E86\u8BC1\u660E\uFF0C\u4F46\u7CFB\u7EDF\u8FD8\u662F\u8BF4\u201C\u4E0D\u4E00\u81F4\u201D\u3002\u6211\u53EA\u662F\u5E0C\u671B\u6709\u4EBA\u771F\u7684\u770B\u4E00\u773C\u3002"
  transferText: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\n\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
  requiresEvidenceSelection: 1
  allowDirectEvidenceSave: 1
  finishOnEvidenceSubmission: 1
  evidencePromptText: "\u8BF7\u9009\u62E9\u4E00\u6761\u5DF2\u6536\u96C6\u8D44\u6599\u4F5C\u4E3A\u8F6C\u4EBA\u5DE5\u8BC1\u636E\u3002"
  hasEvidence: 1
  evidenceId: EVIDENCE_N1_T02
  correctEvidenceIndex: 1
  onSaveEvidenceText: "\u53D6\u6D88\u5F02\u5E38\u6807\u8BB0\uFF0C\u8F6C\u4EA4\u4EBA\u5DE5\u62DB\u8058\u590D\u6838\u3002"
  onWrongEvidenceText: "\u8BC1\u636E\u4E0D\u8DB3\u6216\u8BC1\u636E\u5173\u8054\u9519\u8BEF\u3002"
  correctEvidenceUserReply: "\u8C22\u8C22\u3002\u6211\u77E5\u9053\u4E0D\u4E00\u5B9A\u6709\u7ED3\u679C\uFF0C\u4F46\u81F3\u5C11\u8FD9\u4E00\u6B21\u4E0D\u662F\u88AB\u4E00\u4E2A\u6807\u7B7E\u76F4\u63A5\u5237\u6389\u3002\u6211\u771F\u7684\u53EA\u662F\u60F3\u8981\u4E00\u4E2A\u6B63\u5E38\u89E3\u91CA\u7684\u673A\u4F1A\u3002"
  wrongEvidenceUserReply: "\u5982\u679C\u8FD8\u662F\u53EA\u770B\u8FD9\u4E2A\u5F02\u5E38\u6807\u7B7E\uFF0C\u90A3\u5E94\u8BE5\u4E5F\u4E0D\u4F1A\u53D8\u5427\u3002"
  onResolvedText: "\u7B80\u5386\u5DF2\u5C01\u5B58"
