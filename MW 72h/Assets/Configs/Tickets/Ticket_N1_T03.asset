    speakerLabel: "\u8D3A\u9752\u5C9A"
    text: "\u53EF\u4F60\u4EEC\u6839\u672C\u6CA1\u6709\u5B9E\u65F6\u6570\u636E\uFF0C\u5BF9\u4E0D\u5BF9\uFF1F\u5982\u679C\u51FA\u4E86\u4E8B\uFF0C\u6211\u4E00\u5B9A\u8FFD\u7A76\u4F60\u4EEC\u3002"
    fromUser: 1
