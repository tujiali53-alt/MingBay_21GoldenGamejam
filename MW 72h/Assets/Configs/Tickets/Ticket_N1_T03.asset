  evidenceCorrectDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5DF2\u6838\u5BF9\u5065\u5EB7\u8155\u5E26\u65E5\u5FD7\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u4ECA\u65E5\u201C\u79BB\u5E8A\u6B63\u5E38\u201D\u6570\u636E\u6765\u81EA\u6628\u65E5\u7F13\u5B58\u540C\u6B65\uFF0C\u5E76\u975E\u5B9E\u65F6\u76D1\u6D4B\u3002\u8BBE\u5907\u81EA\u51CC\u6668\u8D77\u5DF2\u65AD\u5F00\u8FDE\u63A5\uFF0C\u5F53\u524D\u65E0\u6CD5\u8BC1\u660E\u8001\u4EBA\u72B6\u6001\u6B63\u5E38\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u6211\u4F1A\u5C06\u65AD\u8FDE\u65E5\u5FD7\u8F6C\u4EA4\u4EBA\u5DE5\u7167\u62A4\u90E8\u95E8\u5E76\u89E6\u53D1\u7D27\u6025\u8054\u7CFB\u4EBA\u590D\u6838\u3002"
    fromUser: 0
  - speakerId: User_HeQingLan
    speakerLabel: "\u8D3A\u9752\u5C9A"
    text: "\u9A6C\u4E0A\u8F6C\uFF01\uFF01\u6211\u597D\u5BB3\u6015\u5979\u771F\u51FA\u4EC0\u4E48\u4E8B\uFF01\uFF01"
    fromUser: 1
  evidenceWrongDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u975E\u5E38\u62B1\u6B49\uFF0C\u540E\u53F0\u8FD9\u8FB9\u5E76\u672A\u67E5\u8BE2\u5230\u76F8\u5173\u6570\u636E\uFF0C\u5F53\u524D\u8D44\u6599\u663E\u793A\u7CFB\u7EDF\u5224\u5B9A\u4E3A\u7ECF\u5386\u5339\u914D\u5F02\u5E38\uFF0C\u590D\u6838\u7ED3\u679C\u9700\u7B49\u5F85\u901A\u77E5\u3002"
