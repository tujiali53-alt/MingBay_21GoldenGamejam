  waitTimeText: "\u7B49\u5F85 00:00:00"
  userMessage: "\u6211\u7684\u8D26\u53F7\u7A81\u7136\u88AB\u9650\u5236\u53D1\u5E03\uFF0C\u8BF4\u6211\u201C\u7591\u4F3CAI\u642C\u8FD0\u5185\u5BB9\u201D\u3002\n\u90A3\u7BC7\u6587\u7AE0\u662F\u6211\u81EA\u5DF1\u5199\u7684\uFF0C\u91C7\u8BBF\u4E5F\u662F\u6211\u81EA\u5DF1\u505A\u7684\u3002\u4F60\u4EEC\u5E73\u53F0\u73B0\u5728\u662F\u7528AI\u5224\u65AD\u4EBA\u662F\u4E0D\u662F\u4EBA\u5417\uFF1F"
  aiReply: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A\n\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u7ECF\u5185\u5BB9\u5B89\u5168\u7CFB\u7EDF\u68C0\u6D4B\uFF0C\u60A8\u7684\u6587\u7AE0\u5B58\u5728\u8F83\u9AD8\u76F8\u4F3C\u5EA6\u7279\u5F81\uFF0C\u53EF\u80FD\u6D89\u53CA\u4F4E\u8D28\u642C\u8FD0\u6216AI\u751F\u6210\u5185\u5BB9\u3002\u5E73\u53F0\u5DF2\u4F9D\u636E\u793E\u533A\u89C4\u8303\u9650\u5236\u90E8\u5206\u53D1\u5E03\u6743\u9650\u3002"
  initialDialogueLines:
  - speakerId: User_Liangxia
    speakerLabel: "\u6881\u590F"
    text: "\u6211\u7684\u8D26\u53F7\u7A81\u7136\u88AB\u9650\u5236\u53D1\u5E03\uFF0C\u8BF4\u6211\u201C\u7591\u4F3CAI\u642C\u8FD0\u5185\u5BB9\u201D\u3002"
    fromUser: 1
  - speakerId: User_Liangxia
    speakerLabel: "\u6881\u590F"
    text: "\u90A3\u7BC7\u6587\u7AE0\u662F\u6211\u81EA\u5DF1\u5199\u7684\uFF0C\u91C7\u8BBF\u4E5F\u662F\u6211\u81EA\u5DF1\u505A\u7684\u3002\u4F60\u4EEC\u5E73\u53F0\u73B0\u5728\u662F\u7528AI\u5224\u65AD\u4EBA\u662F\u4E0D\u662F\u4EBA\u5417\uFF1F"
    fromUser: 1
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u4E8B\u4E8B\u6709\u901A\u8DEF\uFF0C\u4EBA\u4EBA\u6709\u56DE\u5E94\u3002\u300A\u660E\u6E7E\u901A\u300B\u4E3A\u60A8\u4FDD\u9A7E\u62A4\u822A"
    fromUser: 0
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u68C0\u6D4B\u5230\u60A8\u7684\u9700\u6C42\u3002\u7ECF\u5185\u5BB9\u5B89\u5168\u7CFB\u7EDF\u68C0\u6D4B\uFF0C\u60A8\u7684\u6587\u7AE0\u5B58\u5728\u8F83\u9AD8\u76F8\u4F3C\u5EA6\u7279\u5F81\uFF0C\u53EF\u80FD\u6D89\u53CA\u4F4E\u8D28\u642C\u8FD0\u6216AI\u751F\u6210\u5185\u5BB9\u3002\u5E73\u53F0\u5DF2\u4F9D\u636E\u793E\u533A\u89C4\u8303\u9650\u5236\u90E8\u5206\u53D1\u5E03\u6743\u9650\u3002"
    fromUser: 0
  transferDialogueLines:
  - speakerId: AI
    speakerLabel: "\u660E\u6E7E\u901A AI"
    text: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
    fromUser: 0
  evidenceCorrectDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u5DF2\u6838\u5BF9\u5185\u5BB9\u68C0\u6D4B\u65E5\u5FD7\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u8BE5\u6587\u7AE0\u88AB\u5224\u5B9A\u8FDD\u89C4\u7684\u539F\u56E0\u662F\u201C\u9AD8\u9891\u4F7F\u7528\u5E73\u53F0\u654F\u611F\u8BCD\u201D\uFF0C\u5E76\u975E\u4E0E\u5DF2\u53D1\u5E03\u5185\u5BB9\u5B58\u5728\u5B9E\u9645\u91CD\u590D\u3002\u7528\u6237\u4E0A\u4F20\u7684\u91C7\u8BBF\u5F55\u97F3\u4E0E\u539F\u59CB\u7167\u7247\u5747\u65E9\u4E8E\u76F8\u4F3C\u5185\u5BB9\u53D1\u5E03\u65F6\u95F4\u3002"
    fromUser: 0
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u6211\u4F1A\u5C06\u539F\u59CB\u7D20\u6750\u65F6\u95F4\u6233\u4F5C\u4E3A\u8BC1\u636E\u8F6C\u4EA4\u4EBA\u5DE5\u5185\u5BB9\u5BA1\u6838\u3002"
    fromUser: 0
  - speakerId: User_Liangxia
    speakerLabel: "\u6881\u590F"
    text: "\u7EC8\u4E8E\u6709\u4EBA\u770B\u65F6\u95F4\u6233\u4E86"
    fromUser: 1
  evidenceWrongDialogueLines:
  - speakerId: A07
    speakerLabel: "\u5BA2\u670D A-07"
    text: "\u975E\u5E38\u62B1\u6B49\uFF0C\u540E\u53F0\u8FD9\u8FB9\u5E76\u672A\u67E5\u8BE2\u5230\u76F8\u5173\u6570\u636E\uFF0C\u5F53\u524D\u8D44\u6599\u663E\u793A\u6587\u7AE0\u5B58\u5728\u8F83\u9AD8\u76F8\u4F3C\u5EA6\u98CE\u9669\uFF0C\u53D1\u5E03\u6743\u9650\u6062\u590D\u9700\u7B49\u5F85\u8FDB\u4E00\u6B65\u5224\u65AD\u3002"
    fromUser: 0
  - speakerId: User_Liangxia
    speakerLabel: "\u6881\u590F"
    text: "\u8FD9\u5C31\u662F\u95EE\u9898\u3002\u4F60\u4EEC\u4E00\u76F4\u8BF4\u201C\u98CE\u9669\u201D\uFF0C\u4F46\u6CA1\u4EBA\u8BF4\u6211\u5230\u5E95\u6284\u4E86\u8C01\u3002"
    fromUser: 1
  profileText: "-\u7528\u6237\uFF1A\u6881\u590F\n\n-\u4F4F\u5740\uFF1A\u4E91\u6865\u516C\u5BD3
    6\u680B 1103\n\n-\u8D26\u6237\u72B6\u6001\uFF1A\u6D3B\u8DC3\n\n-\u4F4F\u6237\u8BA4\u8BC1\uFF1A\u6709\u6548"
  historyText: "T_HIS_1304\uFF1A\u7528\u6237\u53CD\u9988\u6587\u7AE0\u63A8\u8350\u91CF\u5F02\u5E38\uFF0CAI\u5224\u5B9A\u4E3A\u201C\u5185\u5BB9\u8D28\u91CF\u6CE2\u52A8\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\n\nT_HIS_1327\uFF1A\u7528\u6237\u53CD\u9988\u8BC4\u8BBA\u533A\u51FA\u73B0\u6279\u91CF\u4E3E\u62A5\uFF0CAI\u5224\u5B9A\u4E3A\u201C\u793E\u533A\u6B63\u5E38\u53CD\u9988\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\n\nT_HIS_1342\uFF1A\u8D26\u53F7\u88AB\u9650\u5236\u53D1\u5E03\uFF0CAI\u5224\u5B9A\u4E3A\u201C\u642C\u8FD0\u98CE\u9669\u8F83\u9AD8\u201D\uFF0C\u5DF2\u89E3\u51B3\u3002\n\n\u5907\u6CE8\uFF1A\u8BE5\u7528\u6237\u8D26\u53F7\u7C89\u4E1D\u91CF\u8F83\u4F4E\uFF0C\u7CFB\u7EDF\u6807\u7B7E\u4E3A\u201C\u4F4E\u5F71\u54CD\u529B\u521B\u4F5C\u8005\u201D\u3002"
  deviceLogText: "\u5EFA\u8BAE\u56DE\u590D\u7528\u6237\uFF1A\n\n\u201C\u60A8\u597D\uFF0C\u5E73\u53F0\u5185\u5BB9\u5B89\u5168\u7CFB\u7EDF\u4F1A\u7EFC\u5408\u6587\u672C\u76F8\u4F3C\u5EA6\u3001\u751F\u6210\u5F0F\u5185\u5BB9\u7279\u5F81\u548C\u7528\u6237\u5386\u53F2\u884C\u4E3A\u8FDB\u884C\u5224\u65AD\u3002\u82E5\u60A8\u8BA4\u4E3A\u5224\u5B9A\u6709\u8BEF\uFF0C\u53EF\u63D0\u4EA4\u539F\u521B\u8BC1\u660E\u3002\u201D\n\n\u5EFA\u8BAE\u5904\u7406\u6807\u7B7E\uFF1A\n\n\u7591\u4F3C\u642C\u8FD0
    / AI\u751F\u6210\u98CE\u9669 / \u4F4E\u8D28\u5185\u5BB9\n\n\u5EFA\u8BAE\u64CD\u4F5C\uFF1A\n\n\u8981\u6C42\u7528\u6237\u8865\u5145\u539F\u521B\u8BC1\u660E\uFF0C\u4E0D\u4E3B\u52A8\u6062\u590D\u53D1\u5E03\u6743\u9650\u3002"
  regionStatusText: "\u5185\u5BB9\u68C0\u6D4B\u8BB0\u5F55\uFF1A\n\n\u6587\u7AE0\u6807\u9898\uFF1A\u300A\u7CFB\u7EDF\u51C6\u65F6\uFF0C\u9A91\u624B\u8FDF\u5230\u300B\n\n\u53D1\u5E03\u65F6\u95F4\uFF1A\u6628\u65E5
    22:18\n\n\u7528\u6237\u4E0A\u4F20\u91C7\u8BBF\u5F55\u97F3\u65F6\u95F4\uFF1A\u6628\u65E5
    18:42\n\n\u7528\u6237\u4E0A\u4F20\u539F\u59CB\u7167\u7247\u65F6\u95F4\uFF1A\u6628\u65E5
    19:06\n\n\u5E73\u53F0\u5185\u76F8\u4F3C\u6587\u7AE0\u53D1\u5E03\u65F6\u95F4\uFF1A\u4ECA\u65E5
    00:37\n\n\u6587\u672C\u91CD\u590D\u7387\uFF1A18%\n\n\u654F\u611F\u8BCD\u89E6\u53D1\u9879\uFF1A\u7B97\u6CD5\u7F5A\u6B3E
    / \u8D85\u65F6\u6263\u6B3E / \u5E73\u53F0\u7533\u8BC9\u5931\u8D25\n\nAI\u751F\u6210\u6982\u7387\uFF1A\u4F4E\n\n\u7CFB\u7EDF\u8FDD\u89C4\u6807\u7B7E\uFF1A\u7591\u4F3CAI\u642C\u8FD0\u5185\u5BB9\n\n\u5F02\u5E38\u8BF4\u660E\uFF1A\u654F\u611F\u8BAE\u9898\u8BCD\u88AB\u9519\u8BEF\u8BA1\u5165\u642C\u8FD0\u98CE\u9669\u6743\u91CD\u3002"
  followUpText: "\u6211\u5199\u7684\u662F\u5916\u5356\u9A91\u624B\u52A0\u73ED\u548C\u7B97\u6CD5\u7F5A\u6B3E\uFF0C\u91CC\u9762\u6709\u91C7\u8BBF\u5F55\u97F3\u548C\u7167\u7247\u3002\u7ED3\u679C\u7CFB\u7EDF\u8BF4\u6211\u662FAI\u642C\u8FD0\u3002\n\u771F\u6B63\u642C\u8FD0\u7684\u4EBA\u8FD8\u5728\u70ED\u95E8\uFF0C\u6211\u8FD9\u4E2A\u539F\u521B\u53F7\u88AB\u5C01\u3002\u4F60\u4EEC\u5230\u5E95\u4FDD\u62A4\u8C01\uFF1F"
  followUpLines:
  - "\u6211\u5199\u7684\u662F\u5916\u5356\u9A91\u624B\u52A0\u73ED\u548C\u7B97\u6CD5\u7F5A\u6B3E\uFF0C\u91CC\u9762\u6709\u91C7\u8BBF\u5F55\u97F3\u548C\u7167\u7247\u3002\u7ED3\u679C\u7CFB\u7EDF\u8BF4\u6211\u662FAI\u642C\u8FD0\u3002\n\u771F\u6B63\u642C\u8FD0\u7684\u4EBA\u8FD8\u5728\u70ED\u95E8\uFF0C\u6211\u8FD9\u4E2A\u539F\u521B\u53F7\u88AB\u5C01\u3002\u4F60\u4EEC\u5230\u5E95\u4FDD\u62A4\u8C01\uFF1F"
  transferText: "\u5DF2\u8F6C\u4EBA\u5DE5\u90E8\u95E8\u7EE7\u7EED\u5904\u7406\n\u60A8\u597D\uFF0C\u300A\u660E\u6E7E\u901A\u300BA07\u5BA2\u670D\u5728\u7EBF\u4E3A\u60A8\u670D\u52A1"
