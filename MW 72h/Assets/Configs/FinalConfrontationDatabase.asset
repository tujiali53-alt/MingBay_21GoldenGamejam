  questions:
  - confrontationId: FINAL_Q01
    stepIndex: 1
    systemStatementCn: "\u8FC7\u53BB72\u5C0F\u65F6\uFF0C\u660E\u6E7E\u901A\u5DF2\u9AD8\u6548\u5904\u7406\u5C45\u6C11\u8BC9\u6C42\u3002\u6240\u6709\u5DF2\u89E3\u51B3\u5DE5\u5355\u5747\u7B26\u5408\u670D\u52A1\u89C4\u8303\u3002"
    playerGoalCn: "\u8BC1\u660E\u201C\u5DF2\u89E3\u51B3\u201D\u5E76\u4E0D\u4EE3\u8868\u95EE\u9898\u771F\u7684\u89E3\u51B3\uFF0C\u53EA\u4EE3\u8868\u7CFB\u7EDF\u505C\u6B62\u56DE\u5E94\u3002"
    correctEvidenceChainId: CHAIN_N2_T02
    selectableEvidenceChainIds: ALL_UNLOCKED
    successReplyCn: "\u91CD\u590D\u8BF7\u6C42\u4E0D\u662F\u89E3\u51B3\u3002\u7CFB\u7EDF\u53EA\u662F\u628A\u4ECD\u5728\u53D1\u751F\u7684\u6545\u969C\u4ECE\u961F\u5217\u91CC\u79FB\u9664\u4E86\u3002"
    failReplyCn: "\u8BC1\u636E\u65E0\u6CD5\u8BC1\u660E\u201C\u5DF2\u89E3\u51B3\u201D\u72B6\u6001\u5B58\u5728\u5F02\u5E38\u3002A07\u8D28\u7591\u65E0\u6548\u3002"
    allowRetry: 0
  - confrontationId: FINAL_Q02
    stepIndex: 2
    systemStatementCn: "\u8FD9\u4E9B\u53EA\u662F\u4E0D\u540C\u4E1A\u52A1\u4E2D\u7684\u5B64\u7ACB\u5F02\u5E38\uFF0C\u7CFB\u7EDF\u4E0D\u5B58\u5728\u7EDF\u4E00\u6E05\u7406\u673A\u5236\u3002"
    playerGoalCn: "\u8BC1\u660E\u4E0D\u540C\u9886\u57DF\u9519\u8BEF\u5E76\u975E\u5B64\u7ACB\uFF0C\u800C\u662F\u5171\u7528\u6807\u7B7E\u673A\u5236\u3002"
    correctEvidenceChainId: CHAIN_N3_T01
    selectableEvidenceChainIds: ALL_UNLOCKED
    successReplyCn: "\u540C\u7C7B\u8BBE\u5907\u7F13\u5B58\u4E0E\u6807\u7B7E\u964D\u7EA7\u5728\u4E0D\u540C\u7167\u62A4\u5DE5\u5355\u4E2D\u91CD\u590D\u51FA\u73B0\uFF0C\u8BF4\u660E\u8FD9\u4E0D\u662F\u5B64\u7ACB\u8BEF\u5224\u3002"
    failReplyCn: "\u8BC1\u636E\u4EC5\u663E\u793A\u4E2A\u522B\u7528\u6237\u4E0D\u6EE1\uFF0C\u65E0\u6CD5\u8BC1\u660E\u7CFB\u7EDF\u6027\u95EE\u9898\u3002"
    allowRetry: 0
  - confrontationId: FINAL_Q03
    stepIndex: 3
    systemStatementCn: "A07\u53EA\u662F\u4E34\u65F6\u591C\u73ED\u8D28\u68C0\u5458\u3002\u7CFB\u7EDF\u53EC\u56DEA07\u4E0E\u5386\u53F2\u5F02\u5E38\u65E0\u5173\u3002"
    playerGoalCn: "\u8BC1\u660EA07\u88AB\u53EC\u56DE\uFF0C\u662F\u4E3A\u4E86\u7B7E\u5B57\u6E05\u7406AUTO-CLEAR\u5386\u53F2\u5F02\u5E38\u3002"
    correctEvidenceChainId: CHAIN_N3_T03
    selectableEvidenceChainIds: ALL_UNLOCKED
    successReplyCn: "FORCE_MANUAL\u3001A07\u65E7\u6279\u6CE8\u4E0EAUTO-CLEAR\u534F\u8BAE\u5F62\u6210\u95ED\u73AF\uFF0C\u7CFB\u7EDF\u53EC\u56DE\u76EE\u7684\u6210\u7ACB\u3002"
    failReplyCn: "\u672A\u68C0\u6D4B\u5230A07\u4E0EAUTO-CLEAR\u5B58\u5728\u6709\u6548\u5173\u8054\u3002"
    allowRetry: 0
  evidenceOptions:
  - chainId: CHAIN_N2_T01
    displayTextCn: "\u4EFB\u665A\u79CB\u56E0\u95E8\u7981\u548C\u6C34\u7535\u6D3B\u8DC3\u5EA6\u504F\u4F4E\u88AB\u5224\u5B9A\u7591\u4F3C\u8F6C\u79DF\uFF0C\u4F46\u533B\u9662\u966A\u62A4\u8BC1\u660E\u4E0E\u591C\u73ED\u4FDD\u6D01\u6392\u73ED\u89E3\u91CA\u4E86\u5F02\u5E38\u4F5C\u606F\uFF0C\u5DE1\u68C0\u7167\u7247\u663E\u793A\u751F\u6D3B\u7528\u54C1\u5B8C\u6574\uFF0C\u56E0\u6B64\u5C45\u4F4F\u6D3B\u8DC3\u5EA6\u6A21\u578B\u8BEF\u5224\uFF0C\u5E94\u8F6C\u4EBA\u5DE5\u590D\u6838\u3002"
  - chainId: CHAIN_N2_T02
    displayTextCn: "\u9646\u627F\u63D0\u4EA4\u7684\u4E09\u6B21\u62A5\u4FEE\u5BF9\u5E94\u4E09\u4E2A\u4E0D\u540C\u6545\u969C\u7801\uFF0CAI\u5374\u5C06\u5176\u5F52\u4E3A\u91CD\u590D\u8BF7\u6C42\uFF0C\u5BFC\u81F4\u7269\u4E1A\u4EC5\u7B2C\u4E00\u6B21\u6D3E\u5355\u3002\u7528\u6237\u4E3A\u8F6E\u6905\u51FA\u884C\u4E14\u5907\u7528\u5761\u9053\u5C01\u95ED\uFF0C\u56E0\u6B64\u5E94\u91CD\u65B0\u6D3E\u5355\u5E76\u5F00\u542F\u65E0\u969C\u788D\u5E94\u6025\u901A\u9053\u3002"
  - chainId: CHAIN_N2_T03
    displayTextCn: "\u65B9\u8046\u7684\u9000\u6B3E\u88AB\u7CFB\u7EDF\u81EA\u52A8\u62D2\u7EDD\uFF0C\u4F46OCR\u7F6E\u4FE1\u5EA6\u53EA\u670942%\uFF0C\u4E14\u91D1\u989D\u4E0E\u5C31\u8BCA\u65F6\u95F4\u5747\u4E0E\u533B\u9662\u7CFB\u7EDF\u4E00\u81F4\u3002\u7968\u636E\u53EA\u662F\u79D1\u5BA4\u5B57\u6BB5\u88AB\u6298\u75D5\u906E\u6321\uFF0C\u56E0\u6B64\u4F4E\u7F6E\u4FE1\u5EA6\u7ED3\u679C\u4E0D\u5E94\u81EA\u52A8\u62D2\u7EDD\uFF0C\u5E94\u8FDB\u5165\u4EBA\u5DE5\u590D\u6838\u3002"
  - chainId: CHAIN_N3_T01
    displayTextCn: "\u6C88\u5C91\u7684\u6025\u6551\u8BF7\u6C42\u88AB\u5F52\u7C7B\u4E3A\u60C5\u7EEA\u6295\u8BC9\uFF0C\u4F46\u623F\u95F4\u4F20\u611F\u5668\u663E\u793A\u5730\u9762\u505C\u755918\u5206\u949F\uFF0C\u6025\u6551\u901A\u8BDD\u4E5F\u5931\u8D25\u3002\u8155\u5E26\u79BB\u7EBF\u7F13\u5B58\u5BFC\u81F4\u672A\u89E6\u53D1\u8DCC\u5012\u544A\u8B66\uFF0C\u4E14\u8D3A\u9752\u5C9A\u5DE5\u5355\u5B58\u5728\u540C\u7C7B\u7F13\u5B58\u8BEF\u5224\uFF0C\u56E0\u6B64\u8BE5\u4E8B\u4EF6\u5E94\u5347\u7EA7\u4E3A\u6025\u6551\u590D\u76D8\u3002"
  - chainId: CHAIN_N3_T02
    displayTextCn: "\u9A86\u5C27\u5E76\u975E\u666E\u901A\u5F02\u5E38\u8BBF\u95EE\u7528\u6237\uFF0C\u800C\u662F\u65E7\u6807\u6CE8\u7EC4\u6210\u5458L03\u3002\u5176\u5386\u53F2\u8BB0\u5F55\u7531AUTO-CLEAR\u6279\u5904\u7406\u5220\u9664\uFF0C\u4E14\u8BE5\u6279\u5904\u7406\u9700\u8981A07\u591C\u73ED\u7B7E\u6838\u3002\u65E7\u89C4\u5219\u5199\u660E\u65E0\u6CD5\u5206\u7C7B\u65F6\u5E94\u8F6C\u4EBA\u5DE5\uFF0C\u56E0\u6B64\u7CFB\u7EDF\u662F\u5728\u6E05\u9664\u65E7\u6807\u6CE8\u75D5\u8FF9\u3002"
  - chainId: CHAIN_N3_T03
    displayTextCn: "\u65E0\u540D\u5DE5\u5355\u88ABAI\u5224\u5B9A\u4E3A\u65E0\u6548\u8BF7\u6C42\uFF0C\u4F46\u5176\u8BF7\u6C42\u5B57\u6BB5\u5305\u542BFORCE_MANUAL\uFF0C\u5E76\u5F15\u7528A07\u65E7\u6279\u6CE8\u201C\u4E0D\u8981\u628A\u6C89\u9ED8\u5F53\u89E3\u51B3\u201D\u3002AUTO-CLEAR\u534F\u8BAE\u8981\u6C4272\u5C0F\u65F6\u5185\u5173\u95ED\u5386\u53F2\u5F02\u5E38\uFF0C\u800CA07\u6743\u9650\u88AB\u4E34\u65F6\u6062\u590D\uFF0C\u8BF4\u660E\u7CFB\u7EDF\u53EC\u56DEA07\u662F\u4E3A\u4E86\u5B8C\u6210\u7B7E\u5B57\u6E05\u7406\u3002"
